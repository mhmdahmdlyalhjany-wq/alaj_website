<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="solutions_page_template" name="Solutions Page">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">

                    <style>
.alaj-sol-big-card { position: relative; height: 360px; border-radius: 8px; overflow: hidden; text-decoration: none; display: block; }
.alaj-sol-big-card .oe_img_bg, .alaj-sol-big-card img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
.alaj-sol-big-card:hover img { transform: scale(1.05); }
.alaj-sol-big-card .alaj-sol-big-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(9,14,59,0.82), rgba(9,14,59,0.28), transparent); padding: 28px; display: flex; flex-direction: column; justify-content: flex-end; }
.alaj-sol-big-card h3 { font-family: var(--alaj-font-heading); color: #fff; font-size: 22px; font-weight: 700; margin: 0 0 8px; }
.alaj-sol-big-card p { color: rgba(255,255,255,0.7); font-size: 13px; line-height: 1.6; margin: 0 0 16px; }
.alaj-sol-link { display: inline-flex; align-items: center; gap: 6px; color: #fff; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; text-decoration: none; }
.alaj-sol-link svg { width: 14px; height: 14px; }
.alaj-service-card .card-body { padding: 24px; border-top: 3px solid transparent; transition: border-color 0.2s; }
.alaj-service-card:hover .card-body { border-top-color: var(--alaj-red); }
.alaj-service-card-icon { width: 44px; height: 44px; border-radius: 10px; background: rgba(225,38,28,0.08); display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }
.alaj-service-card-icon svg { width: 22px; height: 22px; color: var(--alaj-red); }
.alaj-cta-banner { background: var(--alaj-navy); border-radius: 8px; padding: 40px; display: flex; align-items: center; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
@media (min-width: 768px) { .alaj-cta-banner { padding: 48px; } }
.alaj-cta-banner h3 { font-family: var(--alaj-font-heading); color: #fff; font-size: clamp(1.2rem, 2.5vw, 1.6rem); font-weight: 700; margin: 0; max-width: 500px; }
                    </style>

                    <section class="alaj-page-banner oe_img_bg" style="background-image: url('/alaj_website/static/src/binary/heroes/hero-home-default.jpg');" data-name="Page Hero">
                        <div class="alaj-banner-overlay">
                            <div class="container">
                                <h1>Solutions <span class="alaj-heading-ampersand">&amp;</span> Services</h1>
                                <div class="alaj-breadcrumb">
                                    <a href="/">Home</a>
                                    <span>/</span>
                                    <span class="active">Solutions</span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt-5 pb-5" data-name="Solutions Intro">
                        <div class="container">
                            <div class="text-center mb-4" style="max-width:700px;margin-left:auto;margin-right:auto;">
                                <span class="alaj-kicker">What We Offer</span>
                                <h2 class="alaj-heading">Comprehensive Laboratory Solutions</h2>
                                <p class="alaj-copy" style="margin:0 auto;">We provide comprehensive solutions covering chemical and reagent supply, advanced laboratory equipment, maintenance services, and dedicated after-sales support for all your laboratory needs.</p>
                            </div>
                            <div class="row mb-5">
                                <div class="col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/products" class="alaj-sol-big-card" data-name="Solution Card">
                                        <img src="/alaj_website/static/src/binary/heroes/hero-overlay.jpg" alt="Chemical and Reagents"/>
                                        <div class="alaj-sol-big-overlay">
                                            <h3>Chemical and Reagents</h3>
                                            <p>Premium quality chemicals and reagents sourced from world-leading manufacturers for accurate laboratory results.</p>
                                            <span class="alaj-sol-link">Learn More <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                        </div>
                                    </a>
                                </div>
                                <div class="col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/products" class="alaj-sol-big-card" data-name="Solution Card">
                                        <img src="/alaj_website/static/src/binary/heroes/hero-main.jpg" alt="Equipment"/>
                                        <div class="alaj-sol-big-overlay">
                                            <h3>Equipment and Instruments</h3>
                                            <p>State-of-the-art laboratory instruments from global manufacturers including HACH, ABB, Sigma and more.</p>
                                            <span class="alaj-sol-link">Learn More <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                        </div>
                                    </a>
                                </div>
                                <div class="col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/contact" class="alaj-sol-big-card" data-name="Solution Card">
                                        <img src="/alaj_website/static/src/binary/heroes/hero-blur.jpg" alt="Maintenance"/>
                                        <div class="alaj-sol-big-overlay">
                                            <h3>Maintenance and Spare Parts</h3>
                                            <p>Professional maintenance services and genuine spare parts to keep your laboratory equipment running at peak performance.</p>
                                            <span class="alaj-sol-link">Learn More <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                        </div>
                                    </a>
                                </div>
                                <div class="col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/contact" class="alaj-sol-big-card" data-name="Solution Card">
                                        <img src="/alaj_website/static/src/binary/heroes/hero-overlay.jpg" alt="After Sales"/>
                                        <div class="alaj-sol-big-overlay">
                                            <h3>After Sales Support</h3>
                                            <p>Dedicated technical support team providing training, calibration, and ongoing assistance for all equipment and instruments.</p>
                                            <span class="alaj-sol-link">Learn More <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                        </div>
                                    </a>
                                </div>
                            </div>

                            <div class="mb-4">
                                <span class="alaj-kicker">Core Services</span>
                                <h2 class="alaj-heading">Our Core Services</h2>
                            </div>
                            <div class="row mb-5">
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-service-card" data-name="Service Card">
                                        <div class="card-body">
                                            <div class="alaj-service-card-icon">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
                                            </div>
                                            <h3 class="card-title">Installation</h3>
                                            <p class="card-text">Professional installation services for all laboratory equipment ensuring optimal setup and configuration.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-service-card" data-name="Service Card">
                                        <div class="card-body">
                                            <div class="alaj-service-card-icon">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                                            </div>
                                            <h3 class="card-title">Training</h3>
                                            <p class="card-text">Comprehensive training programs for laboratory staff on equipment operation, safety protocols, and best practices.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-service-card" data-name="Service Card">
                                        <div class="card-body">
                                            <div class="alaj-service-card-icon">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                                            </div>
                                            <h3 class="card-title">Calibration</h3>
                                            <p class="card-text">Precision calibration services to ensure your instruments deliver accurate and reliable measurements.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-service-card" data-name="Service Card">
                                        <div class="card-body">
                                            <div class="alaj-service-card-icon">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                                            </div>
                                            <h3 class="card-title">Preventive Maintenance</h3>
                                            <p class="card-text">Scheduled maintenance programs to prevent equipment downtime and extend the lifespan of your investments.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-service-card" data-name="Service Card">
                                        <div class="card-body">
                                            <div class="alaj-service-card-icon">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                                            </div>
                                            <h3 class="card-title">Consultation</h3>
                                            <p class="card-text">Expert consultation to help you select the right equipment and solutions for your specific laboratory requirements.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-service-card" data-name="Service Card">
                                        <div class="card-body">
                                            <div class="alaj-service-card-icon">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                                            </div>
                                            <h3 class="card-title">Logistics <span class="alaj-ampersand">&amp;</span> Delivery</h3>
                                            <p class="card-text">Reliable logistics and delivery services ensuring your equipment arrives safely and on time anywhere in the Kingdom.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="alaj-cta-banner">
                                <h3>Need a custom solution for your laboratory? Our team is ready to help.</h3>
                                <a href="/contact" class="btn-red">Contact Us Today</a>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </template>

        <record id="solutions_page" model="website.page">
            <field name="name">Solutions</field>
            <field name="url">/solutions</field>
            <field name="is_published">True</field>
            <field name="view_id" ref="solutions_page_template"/>
            <field name="website_id" ref="alaj_website_record"/>
        </record>

        <record id="menu_solutions" model="website.menu">
            <field name="name">Solutions</field>
            <field name="url">/solutions</field>
            <field name="parent_id" ref="alaj_top_menu"/>
            <field name="website_id" ref="alaj_website_record"/>
            <field name="sequence">30</field>
        </record>

        <record id="solutions_page_template" model="ir.ui.view">
            <field name="website_id" ref="alaj_website_record"/>
        </record>
    </data>
</odoo>
