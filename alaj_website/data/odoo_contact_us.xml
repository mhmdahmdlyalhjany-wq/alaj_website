<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="contact_us_template" name="Contact Us Page">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">

                    <style>
                        #wrap * { box-sizing: border-box; }
                        #wrap {
                            font-family: 'Poppins', 'Helvetica Neue', sans-serif;
                            color: #262138; line-height: 1.6;
                        }
                        .page-banner {
                            position: relative; width: 100%; height: 400px; overflow: hidden;
                            background-size: cover; background-position: center; background-repeat: no-repeat;
                        }
                        .page-banner .banner-overlay {
                            position: absolute; inset: 0;
                            background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 100%);
                            display: flex; flex-direction: column; justify-content: center;
                            padding: 0 56px;
                        }
                        .page-banner .banner-title {
                            color: #fff; font-family: 'Poppins', sans-serif;
                            font-size: 56px; font-weight: 700; margin: 0 0 16px;
                        }
                        .page-banner .breadcrumb {
                            display: flex; align-items: center; gap: 8px;
                            color: rgba(255,255,255,0.7); font-family: 'Poppins', sans-serif; font-size: 14px;
                        }
                        .page-banner .breadcrumb a { color: rgba(255,255,255,0.7); text-decoration: none; }
                        .page-banner .breadcrumb a:hover { color: #fff; }
                        .page-banner .breadcrumb .sep { margin: 0 4px; }
                        .page-banner .breadcrumb .current { color: #E1261C; }

                        .contact-content { width: 100%; padding: 64px 56px; background: #EFF9FF; }
                        .contact-inner { max-width: 1792px; margin: 0 auto; }

                        .contact-grid {
                            display: grid; grid-template-columns: 1fr 1fr; gap: 64px;
                            margin-bottom: 64px;
                        }

                        .contact-form-wrap {
                            background: #fff; border-radius: 20px; padding: 48px;
                            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
                        }
                        .form-title {
                            color: #262138; font-family: 'Poppins', sans-serif;
                            font-size: 28px; font-weight: 600; margin: 0 0 8px;
                        }
                        .form-subtitle {
                            color: #4A4363; font-family: 'Poppins', sans-serif;
                            font-size: 15px; font-weight: 400; margin: 0 0 32px;
                        }
                        .form-group { margin-bottom: 24px; }
                        .form-label {
                            display: block; color: #262138;
                            font-family: 'Poppins', sans-serif;
                            font-size: 14px; font-weight: 500;
                            margin-bottom: 8px;
                        }
                        .form-input {
                            width: 100%; padding: 14px 20px;
                            background: #F8F9FC; border: 1px solid #e5e7eb;
                            border-radius: 12px; font-family: 'Poppins', sans-serif;
                            font-size: 15px; color: #262138;
                            outline: none; transition: border-color 0.2s;
                        }
                        .form-input:focus { border-color: #E1261C; }
                        .form-input::placeholder { color: #9ca3af; }
                        textarea.form-input { min-height: 140px; resize: vertical; }
                        .form-row {
                            display: grid; grid-template-columns: 1fr 1fr; gap: 24px;
                        }
                        .form-submit {
                            display: inline-flex; align-items: center; gap: 12px;
                            padding: 14px 48px; background: #E1261C; color: #fff;
                            border-radius: 9999px; font-family: 'Poppins', sans-serif;
                            font-size: 16px; font-weight: 600;
                            border: none; cursor: pointer; transition: background 0.2s;
                            margin-top: 8px;
                        }
                        .form-submit:hover { background: rgba(225,38,28,0.9); }

                        .contact-info-wrap {}
                        .info-title {
                            color: #262138; font-family: 'Poppins', sans-serif;
                            font-size: 28px; font-weight: 600; margin: 0 0 8px;
                        }
                        .info-subtitle {
                            color: #4A4363; font-family: 'Poppins', sans-serif;
                            font-size: 15px; font-weight: 400; margin: 0 0 40px;
                        }
                        .info-card {
                            background: #fff; border-radius: 20px; padding: 32px;
                            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
                            margin-bottom: 24px;
                            display: flex; align-items: flex-start; gap: 20px;
                        }
                        .info-card-icon {
                            width: 56px; height: 56px; border-radius: 16px;
                            background: rgba(225,38,28,0.08);
                            display: flex; align-items: center; justify-content: center;
                            flex-shrink: 0;
                        }
                        .info-card-icon svg { width: 24px; height: 24px; color: #E1261C; }
                        .info-card-label {
                            color: #4A4363; font-family: 'Poppins', sans-serif;
                            font-size: 13px; font-weight: 400; margin: 0 0 4px;
                            text-transform: uppercase; letter-spacing: 0.05em;
                        }
                        .info-card-value {
                            color: #262138; font-family: 'Poppins', sans-serif;
                            font-size: 16px; font-weight: 500; margin: 0;
                        }

                        .social-section { margin-top: 40px; }
                        .social-title {
                            color: #262138; font-family: 'Poppins', sans-serif;
                            font-size: 18px; font-weight: 600; margin: 0 0 16px;
                        }
                        .social-icons {
                            display: flex; align-items: center; gap: 16px;
                        }
                        .social-icon {
                            width: 48px; height: 48px; border-radius: 50%;
                            background: #F1F3F9; display: flex;
                            align-items: center; justify-content: center;
                            transition: all 0.2s; color: #222;
                            text-decoration: none;
                        }
                        .social-icon:hover { background: #E1261C; color: #fff; }
                        .social-icon svg { width: 20px; height: 20px; }

                        .map-section {
                            background: #fff; border-radius: 20px; overflow: hidden;
                            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
                            height: 400px;
                        }
                        .map-section iframe {
                            width: 100%; height: 100%; border: 0;
                        }
                        .map-placeholder {
                            width: 100%; height: 100%;
                            background: linear-gradient(135deg, #EBF4FF 0%, #D6ECFF 100%);
                            display: flex; align-items: center; justify-content: center;
                            color: #4A4363; font-family: 'Poppins', sans-serif;
                            font-size: 18px; font-weight: 500;
                        }

                        .page-banner .banner-overlay { pointer-events: none; }
                        .page-banner .banner-overlay * { pointer-events: auto; }

                        @media (max-width: 1024px) {
                            .contact-grid { grid-template-columns: 1fr; }
                        }
                        @media (max-width: 768px) {
                            .page-banner .banner-title { font-size: 36px; }
                            .page-banner .banner-overlay { padding: 0 24px; }
                            .form-row { grid-template-columns: 1fr; }
                            .contact-content { padding: 40px 16px; }
                            .contact-form-wrap { padding: 24px; }
                            .info-card { padding: 20px; }
                            .form-title, .info-title { font-size: 22px; }
                            .map-section { height: 280px; }
                        }
                        @media (max-width: 480px) {
                            .page-banner .banner-title { font-size: 28px; }
                            .page-banner { height: 300px; }
                            .contact-content { padding: 24px 12px; }
                            .contact-grid { gap: 32px; }
                        }
                    </style>

                    <section class="page-banner oe_img_bg" style="background-image: url('/alaj_website/static/src/binary/heroes/hero-main.jpg');">
                        <div class="banner-overlay">
                            <h1 class="banner-title">Contact Us</h1>
                            <div class="breadcrumb">
                                <a href="/">Home</a>
                                <span class="sep">&gt;</span>
                                <span class="current">Contact Us</span>
                            </div>
                        </div>
                    </section>

                    <section class="contact-content">
                        <div class="contact-inner">
                            <div class="contact-grid">
                                <div class="contact-form-wrap">
                                    <h2 class="form-title">Get in Touch</h2>
                                    <p class="form-subtitle">We would love to hear from you. Send us a message and we'll respond as soon as possible.</p>

                                    <form action="/contact" method="post">
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label class="form-label">Full Name</label>
                                                <input type="text" class="form-input" placeholder="Enter your full name" name="name"/>
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Email Address</label>
                                                <input type="email" class="form-input" placeholder="Enter your email" name="email"/>
                                            </div>
                                        </div>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label class="form-label">Phone</label>
                                                <input type="tel" class="form-input" placeholder="Enter your phone number" name="phone"/>
                                            </div>
                                            <div class="form-group">
                                                <label class="form-label">Subject</label>
                                                <input type="text" class="form-input" placeholder="Enter subject" name="subject"/>
                                            </div>
                                        </div>
                                        <div class="form-group">
                                            <label class="form-label">Message</label>
                                            <textarea class="form-input" placeholder="Write your message here..." name="message"></textarea>
                                        </div>
                                        <button type="submit" class="form-submit">Send Message</button>
                                    </form>
                                </div>

                                <div class="contact-info-wrap">
                                    <h2 class="info-title">Contact Information</h2>
                                    <p class="info-subtitle">Reach out to us through any of the following channels.</p>

                                    <div class="info-card">
                                        <div class="info-card-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                        </div>
                                        <div>
                                            <p class="info-card-label">Head Office</p>
                                            <p class="info-card-value">P.O. Box 10325, Jeddah, Saudi Arabia</p>
                                        </div>
                                    </div>

                                    <div class="info-card">
                                        <div class="info-card-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                        </div>
                                        <div>
                                            <p class="info-card-label">Phone</p>
                                            <p class="info-card-value">+96654337878</p>
                                        </div>
                                    </div>

                                    <div class="info-card">
                                        <div class="info-card-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                        </div>
                                        <div>
                                            <p class="info-card-label">Fax</p>
                                            <p class="info-card-value">+966 57533041</p>
                                        </div>
                                    </div>

                                    <div class="info-card">
                                        <div class="info-card-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                                        </div>
                                        <div>
                                            <p class="info-card-label">Email</p>
                                            <p class="info-card-value">Sales@alajlabchem.com</p>
                                        </div>
                                    </div>

                                    <div class="social-section">
                                        <h3 class="social-title">Connect with Us</h3>
                                        <div class="social-icons">
                                            <a href="#" class="social-icon" aria-label="Twitter">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
                                            </a>
                                            <a href="#" class="social-icon" aria-label="YouTube">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>
                                            </a>
                                            <a href="#" class="social-icon" aria-label="LinkedIn">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                                            </a>
                                            <a href="#" class="social-icon" aria-label="Instagram">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="map-section">
                                <div class="map-placeholder">
                                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin-right: 16px; color: #4A4363;"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                    Jeddah, Saudi Arabia - Map Location
                                </div>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </template>

        <record id="contact_us_page" model="website.page">
            <field name="name">Contact Us</field>
            <field name="url">/contact</field>
            <field name="is_published">True</field>
            <field name="view_id" ref="contact_us_template"/>
            <field name="website_id" ref="alaj_website_record"/>
        </record>

        <record id="menu_contact" model="website.menu">
            <field name="name">Contact Us</field>
            <field name="url">/contact</field>
            <field name="parent_id" ref="alaj_top_menu"/>
            <field name="website_id" ref="alaj_website_record"/>
            <field name="sequence">60</field>
        </record>

        <record id="contact_us_template" model="ir.ui.view">
            <field name="website_id" ref="alaj_website_record"/>
        </record>

    </data>
</odoo>
