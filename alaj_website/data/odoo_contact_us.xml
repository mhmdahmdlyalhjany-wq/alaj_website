<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="contact_us_template" name="Contact Us Page">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">

                    <style>
.alaj-contact-section { padding: 56px 0; }
@media (min-width: 768px) { .alaj-contact-section { padding: 80px 0; } }
.alaj-contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    margin-bottom: 40px;
}
@media (min-width: 992px) { .alaj-contact-grid { grid-template-columns: 1fr 1fr; gap: 40px; } }
.alaj-contact-form-wrap {
    background: #fff;
    border: 1px solid var(--alaj-border);
    border-radius: 8px;
    padding: 32px;
}
.alaj-form-group { margin-bottom: 16px; }
.alaj-form-label {
    display: block;
    font-size: 12px;
    font-weight: 700;
    color: var(--alaj-charcoal);
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
}
.alaj-form-input {
    width: 100%;
    padding: 10px 14px;
    background: var(--alaj-bg);
    border: 1px solid var(--alaj-border);
    border-radius: 6px;
    font-family: var(--alaj-font-body);
    font-size: 13px;
    color: var(--alaj-charcoal);
    outline: none;
    transition: border-color 0.2s;
}
.alaj-form-input:focus { border-color: var(--alaj-red); }
.alaj-form-input::placeholder { color: var(--alaj-stone); }
textarea.alaj-form-input { min-height: 120px; resize: vertical; }
.alaj-form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
}
@media (max-width: 480px) { .alaj-form-row { grid-template-columns: 1fr; } }

.alaj-info-card {
    background: #fff;
    border: 1px solid var(--alaj-border);
    border-radius: 8px;
    padding: 16px 20px;
    margin-bottom: 12px;
    display: flex;
    align-items: flex-start;
    gap: 16px;
    transition: border-color 0.2s;
}
.alaj-info-card:hover { border-color: rgba(225,38,28,0.3); }
.alaj-info-card-icon {
    width: 40px;
    height: 40px;
    border-radius: 8px;
    background: rgba(225,38,28,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}
.alaj-info-card-icon svg { width: 18px; height: 18px; color: var(--alaj-red); }
.alaj-info-card-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--alaj-stone);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 2px;
}
.alaj-info-card-value {
    font-size: 14px;
    font-weight: 600;
    color: var(--alaj-charcoal);
    margin: 0;
}
.alaj-social-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 24px;
}
.alaj-social-icon {
    width: 38px;
    height: 38px;
    border-radius: 8px;
    background: var(--alaj-bg);
    border: 1px solid var(--alaj-border);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    color: var(--alaj-charcoal);
    text-decoration: none;
}
.alaj-social-icon:hover { background: var(--alaj-red); color: #fff; border-color: var(--alaj-red); }
.alaj-social-icon svg { width: 16px; height: 16px; }
.alaj-map-wrap {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--alaj-border);
    height: 320px;
    background: var(--alaj-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--alaj-stone);
    font-size: 14px;
    font-weight: 600;
}
.alaj-map-wrap svg { margin-right: 12px; color: var(--alaj-stone); }
                    </style>

                    <section class="alaj-page-banner oe_img_bg" style="background-image: url('/alaj_website/static/src/binary/heroes/hero-home-default.jpg');" data-name="Page Hero">
                        <div class="alaj-banner-overlay">
                            <div class="container">
                                <h1>Contact Us</h1>
                                <div class="alaj-breadcrumb">
                                    <a href="/">Home</a>
                                    <span>/</span>
                                    <span class="active">Contact Us</span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt-5 pb-5" data-name="Contact">
                        <div class="container">
                            <div class="row">
                                <div class="col-lg-6 s_col_no_bgcolor pb16">
                                    <div class="alaj-contact-form-wrap" data-name="Contact Form">
                                    <h2 class="alaj-heading" style="margin-bottom:4px;">Get in Touch</h2>
                                    <p class="alaj-copy" style="margin-bottom:24px;">We would love to hear from you. Send us a message and we will respond as soon as possible.</p>

                                    <form action="/contact" method="post">
                                        <div class="alaj-form-row">
                                            <div class="alaj-form-group">
                                                <label class="alaj-form-label">Full Name</label>
                                                <input type="text" class="alaj-form-input" placeholder="Enter your full name" name="name"/>
                                            </div>
                                            <div class="alaj-form-group">
                                                <label class="alaj-form-label">Email Address</label>
                                                <input type="email" class="alaj-form-input" placeholder="Enter your email" name="email"/>
                                            </div>
                                        </div>
                                        <div class="alaj-form-row">
                                            <div class="alaj-form-group">
                                                <label class="alaj-form-label">Phone</label>
                                                <input type="tel" class="alaj-form-input" placeholder="Enter your phone number" name="phone"/>
                                            </div>
                                            <div class="alaj-form-group">
                                                <label class="alaj-form-label">Subject</label>
                                                <input type="text" class="alaj-form-input" placeholder="Enter subject" name="subject"/>
                                            </div>
                                        </div>
                                        <div class="alaj-form-group">
                                            <label class="alaj-form-label">Message</label>
                                            <textarea class="alaj-form-input" placeholder="Write your message here..." name="message"></textarea>
                                        </div>
                                        <button type="submit" class="btn-red" style="margin-top:8px;">Send Message</button>
                                    </form>
                                    </div>
                                </div>

                                <div class="col-lg-6 s_col_no_bgcolor pb16" data-name="Contact Info">
                                    <h2 class="alaj-heading" style="margin-bottom:4px;">Contact Information</h2>
                                    <p class="alaj-copy" style="margin-bottom:24px;">Reach out to us through any of the following channels.</p>

                                    <div class="alaj-info-card">
                                        <div class="alaj-info-card-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                        </div>
                                        <div>
                                            <p class="alaj-info-card-label">Head Office</p>
                                            <p class="alaj-info-card-value">P.O. Box 10325, Jeddah, Saudi Arabia</p>
                                        </div>
                                    </div>

                                    <div class="alaj-info-card">
                                        <div class="alaj-info-card-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                        </div>
                                        <div>
                                            <p class="alaj-info-card-label">Phone</p>
                                            <p class="alaj-info-card-value">+96654337878</p>
                                        </div>
                                    </div>

                                    <div class="alaj-info-card">
                                        <div class="alaj-info-card-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                                        </div>
                                        <div>
                                            <p class="alaj-info-card-label">Fax</p>
                                            <p class="alaj-info-card-value">+966 57533041</p>
                                        </div>
                                    </div>

                                    <div class="alaj-info-card">
                                        <div class="alaj-info-card-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                                        </div>
                                        <div>
                                            <p class="alaj-info-card-label">Email</p>
                                            <p class="alaj-info-card-value">Sales@alajlabchem.com</p>
                                        </div>
                                    </div>

                                    <div class="alaj-social-row">
                                        <a href="#" class="alaj-social-icon" aria-label="Twitter">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
                                        </a>
                                        <a href="#" class="alaj-social-icon" aria-label="YouTube">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/></svg>
                                        </a>
                                        <a href="#" class="alaj-social-icon" aria-label="LinkedIn">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                                        </a>
                                        <a href="#" class="alaj-social-icon" aria-label="Instagram">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <div class="alaj-map-wrap">
                                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                Jeddah, Saudi Arabia - Map Location
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </template>

        <record id="contact_us_page" model="website.page">
            <field name="name">Contact Us</field>
            <field name="url">/contact</field>
            <field name="is_published">True</field>
            <field name="view_id" ref="contact_us_template"/>
            <field name="website_id" ref="alaj_website_record"/>
        </record>

        <record id="menu_contact" model="website.menu">
            <field name="name">Contact Us</field>
            <field name="url">/contact</field>
            <field name="parent_id" ref="alaj_top_menu"/>
            <field name="website_id" ref="alaj_website_record"/>
            <field name="sequence">60</field>
        </record>

        <record id="contact_us_template" model="ir.ui.view">
            <field name="website_id" ref="alaj_website_record"/>
        </record>

    </data>
</odoo>
