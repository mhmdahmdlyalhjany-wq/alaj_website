<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="event_detail_template" name="Event Detail Page">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">

                    <style>
.alaj-ed-section { padding: 56px 0; }
@media (min-width: 768px) { .alaj-ed-section { padding: 80px 0; } }
.alaj-ed-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
}
@media (min-width: 992px) { .alaj-ed-grid { grid-template-columns: 2fr 1fr; gap: 40px; } }
.alaj-ed-main-img {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 24px;
    border: 1px solid var(--alaj-border);
}
.alaj-ed-main-img img {
    width: 100%;
    height: 380px;
    object-fit: cover;
}
@media (max-width: 767px) { .alaj-ed-main-img img { height: 240px; } }
.alaj-ed-meta {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
    flex-wrap: wrap;
}
.alaj-ed-meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--alaj-stone);
    font-weight: 600;
}
.alaj-ed-meta-item svg { width: 14px; height: 14px; }
.alaj-ed-badge {
    display: inline-block;
    padding: 3px 10px;
    background: rgba(225,38,28,0.08);
    color: var(--alaj-red);
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
}
.alaj-ed-title {
    font-family: var(--alaj-font-heading);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--alaj-charcoal);
    margin: 0 0 20px;
    line-height: 1.2;
}
.alaj-sidebar-card {
    background: #fff;
    border: 1px solid var(--alaj-border);
    border-radius: 8px;
    padding: 24px;
    margin-bottom: 20px;
}
.alaj-sidebar-info-item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 16px;
}
.alaj-sidebar-info-item:last-child { margin-bottom: 0; }
.alaj-sidebar-info-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: rgba(225,38,28,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}
.alaj-sidebar-info-icon svg { width: 16px; height: 16px; color: var(--alaj-red); }
.alaj-sidebar-info-label {
    font-size: 11px;
    font-weight: 700;
    color: var(--alaj-stone);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 2px;
}
.alaj-sidebar-info-value {
    font-size: 13px;
    font-weight: 700;
    color: var(--alaj-charcoal);
    margin: 0;
}
.alaj-related-event-card {
    overflow: hidden;
    border-radius: 8px;
    background: #fff;
    border: 1px solid var(--alaj-border);
    text-decoration: none;
    margin-bottom: 12px;
    display: block;
    transition: border-color 0.2s;
}
.alaj-related-event-card:hover { border-color: rgba(225,38,28,0.3); text-decoration: none; }
.alaj-related-event-card-img {
    overflow: hidden;
    height: 140px;
}
.alaj-related-event-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.alaj-related-event-card-body { padding: 14px; }
.alaj-related-event-card-date {
    font-size: 11px;
    font-weight: 700;
    color: var(--alaj-red);
    margin: 0 0 4px;
}
.alaj-related-event-card-title {
    font-size: 13px;
    font-weight: 700;
    color: var(--alaj-charcoal);
    margin: 0;
    line-height: 1.4;
}
                    </style>

                    <section class="alaj-page-banner oe_img_bg" style="background-image: url('/alaj_website/static/src/binary/heroes/hero-home-default.jpg');" data-name="Page Hero">
                        <div class="alaj-banner-overlay">
                            <div class="container">
                                <h1>Event Details</h1>
                                <div class="alaj-breadcrumb">
                                    <a href="/">Home</a>
                                    <span>/</span>
                                    <a href="/events">Media Center</a>
                                    <span>/</span>
                                    <span class="active">Event Detail</span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt-5 pb-5" data-name="Event Detail">
                        <div class="container">
                            <div class="row">
                                <div class="col-lg-8 s_col_no_bgcolor pb16" data-name="Event Main">
                                    <div class="alaj-ed-main-img">
                                        <img src="/alaj_website/static/src/binary/news/featured-article.jpg" alt="Saudi International Lab Expo 2025"/>
                                    </div>
                                    <div class="alaj-ed-meta">
                                        <div class="alaj-ed-meta-item">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                            12 March 2025
                                        </div>
                                        <div class="alaj-ed-meta-item">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                            Riyadh, KSA
                                        </div>
                                        <span class="alaj-ed-badge">Exhibition</span>
                                    </div>
                                    <h1 class="alaj-ed-title">Saudi International Lab Expo 2025</h1>
                                    <p class="alaj-copy" style="margin-bottom:16px;">Join us at the Saudi International Lab Expo 2025, the largest laboratory equipment and chemical analysis exhibition in the Kingdom of Saudi Arabia. This premier event brings together industry leaders, researchers, and professionals from across the region.</p>
                                    <p class="alaj-copy" style="margin-bottom:24px;">Discover the latest innovations in chemical analysis and research instruments. Our team will be showcasing cutting-edge products and solutions designed to meet the evolving needs of laboratories across the Kingdom.</p>
                                    <a href="/contact" class="btn-red">Contact Us</a>
                                </div>

                                <div class="col-lg-4 s_col_no_bgcolor pb16" data-name="Event Sidebar">
                                    <div class="alaj-sidebar-card">
                                        <h3 style="font-family:var(--alaj-font-body);font-size:15px;font-weight:700;color:var(--alaj-charcoal);margin:0 0 20px;">Event Details</h3>
                                        <div class="alaj-sidebar-info-item">
                                            <div class="alaj-sidebar-info-icon">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                            </div>
                                            <div>
                                                <p class="alaj-sidebar-info-label">Date</p>
                                                <p class="alaj-sidebar-info-value">12 March 2025</p>
                                            </div>
                                        </div>
                                        <div class="alaj-sidebar-info-item">
                                            <div class="alaj-sidebar-info-icon">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                            </div>
                                            <div>
                                                <p class="alaj-sidebar-info-label">Location</p>
                                                <p class="alaj-sidebar-info-value">Riyadh, KSA</p>
                                            </div>
                                        </div>
                                        <div class="alaj-sidebar-info-item">
                                            <div class="alaj-sidebar-info-icon">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                            </div>
                                            <div>
                                                <p class="alaj-sidebar-info-label">Time</p>
                                                <p class="alaj-sidebar-info-value">9:00 AM - 6:00 PM</p>
                                            </div>
                                        </div>
                                        <div class="alaj-sidebar-info-item">
                                            <div class="alaj-sidebar-info-icon">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
                                            </div>
                                            <div>
                                                <p class="alaj-sidebar-info-label">Category</p>
                                                <p class="alaj-sidebar-info-value">Exhibition</p>
                                            </div>
                                        </div>
                                    </div>

                                    <h3 style="font-family:var(--alaj-font-body);font-size:15px;font-weight:700;color:var(--alaj-charcoal);margin:0 0 12px;">Related Events</h3>
                                    <a href="/event-detail" class="alaj-related-event-card" data-name="Related Event">
                                        <div class="alaj-related-event-card-img"><img src="/alaj_website/static/src/binary/news/event-1.jpg" alt="Event"/></div>
                                        <div class="alaj-related-event-card-body">
                                            <p class="alaj-related-event-card-date">25 Feb 2025</p>
                                            <p class="alaj-related-event-card-title">Advanced Spectral Colorimeters Launch</p>
                                        </div>
                                    </a>
                                    <a href="/event-detail" class="alaj-related-event-card" data-name="Related Event">
                                        <div class="alaj-related-event-card-img"><img src="/alaj_website/static/src/binary/news/event-2.jpg" alt="Event"/></div>
                                        <div class="alaj-related-event-card-body">
                                            <p class="alaj-related-event-card-date">10 Jan 2025</p>
                                            <p class="alaj-related-event-card-title">Annual Quality Workshop for Lab Professionals</p>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </template>

        <record id="event_detail_page" model="website.page">
            <field name="name">Event Detail</field>
            <field name="url">/event-detail</field>
            <field name="is_published">True</field>
            <field name="view_id" ref="event_detail_template"/>
            <field name="website_id" ref="alaj_website_record"/>
        </record>

        <record id="event_detail_template" model="ir.ui.view">
            <field name="website_id" ref="alaj_website_record"/>
        </record>

    </data>
</odoo>
