            <field name="public_categ_ids" eval="[(6, 0, [ref('public_category_analyzers')])]"/>
            <field name="product_tag_ids" eval="[(6, 0, [ref('product_tag_hach'), ref('product_tag_benchtop'), ref('product_tag_premium')])]"/>
