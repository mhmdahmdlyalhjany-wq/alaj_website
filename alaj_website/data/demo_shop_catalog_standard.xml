        <record id="product_balance_scale" model="product.template">
            <field name="website_id" ref="alaj_website_record"/>
            <field name="default_code">BAL-2000-1G</field>
            <field name="website_sequence">10</field>
            <field name="list_price">850.00</field>
            <field name="description_sale">Compact laboratory balance with 2000 g capacity and 1 g readability for routine sample preparation and quality control.</field>
            <field name="website_description" type="html">
                <p>Compact laboratory balance designed for daily weighing tasks with dependable repeatability.</p>
                <ul>
                    <li>Capacity: 2000 g</li>
                    <li>Readability: 1 g</li>
                    <li>Ideal for routine sample preparation and QC workflows</li>
                </ul>
            </field>
            <field name="image_1920" type="base64" file="alaj_website/static/src/binary/products/balance-scale.png"/>
            <field name="public_categ_ids" eval="[(6, 0, [ref('public_category_instruments')])]"/>
            <field name="product_tag_ids" eval="[(6, 0, [ref('product_tag_benchtop'), ref('product_tag_research'), ref('product_tag_premium')])]"/>
        </record>

        <record id="product_dr6000" model="product.template">
            <field name="website_id" ref="alaj_website_record"/>
            <field name="categ_id" ref="product_category_analyzers"/>
            <field name="default_code">HACH-DR6000</field>
            <field name="website_sequence">20</field>
            <field name="list_price">12500.00</field>
            <field name="description_sale">High-performance UV-VIS spectrophotometer for laboratory water analysis with pre-programmed methods and USB connectivity.</field>
            <field name="website_description" type="html">
                <p>Advanced UV-VIS spectrophotometer engineered for accurate laboratory water analysis.</p>
                <ul>
                    <li>Wavelength range: 190-1100 nm</li>
                    <li>Digital touch interface with pre-programmed methods</li>
                    <li>Built for demanding analytical laboratories</li>
                </ul>
            </field>
            <field name="image_1920" type="base64" file="alaj_website/static/src/binary/products/dr-6000.png"/>
            <field name="public_categ_ids" eval="[(6, 0, [ref('public_category_analyzers')])]"/>
            <field name="product_tag_ids" eval="[(6, 0, [ref('product_tag_hach'), ref('product_tag_benchtop'), ref('product_tag_water_analysis')])]"/>
        </record>

        <record id="product_hq1110" model="product.template">
            <field name="website_id" ref="alaj_website_record"/>
            <field name="default_code">HQ1110-PH</field>
            <field name="website_sequence">30</field>
            <field name="list_price">2200.00</field>
            <field name="description_sale">Portable pH/ORP meter for field and laboratory use with IntelliCAL probe compatibility and onboard data logging.</field>
            <field name="website_description" type="html">
                <p>Portable pH/ORP meter ready for field testing, site inspection, and fast laboratory verification.</p>
                <ul>
                    <li>Compatible with IntelliCAL probes</li>
                    <li>Built-in data logging and USB connectivity</li>
                    <li>Water-resistant design for demanding environments</li>
                </ul>
            </field>
            <field name="image_1920" type="base64" file="alaj_website/static/src/binary/products/hq1110-meter.png"/>
            <field name="public_categ_ids" eval="[(6, 0, [ref('public_category_instruments')])]"/>
            <field name="product_tag_ids" eval="[(6, 0, [ref('product_tag_hach'), ref('product_tag_portable'), ref('product_tag_water_analysis')])]"/>
        </record>

