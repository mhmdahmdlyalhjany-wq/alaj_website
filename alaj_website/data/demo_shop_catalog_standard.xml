            <field name="website_id" ref="alaj_website_record"/>
            <field name="categ_id" ref="product_category_analyzers"/>
            <field name="default_code">LICO-690</field>
            <field name="website_sequence">40</field>
            <field name="list_price">8900.00</field>
            <field name="description_sale">Professional spectral colorimeter for precise liquid and solid color analysis in quality control laboratories.</field>
            <field name="website_description" type="html">
                <p>Professional spectral colorimeter developed for reliable color measurement in laboratory and production environments.</p>
                <ul>
                    <li>Advanced optical system for repeatable measurements</li>
                    <li>Suitable for water, chemical, and pharmaceutical QC</li>
                    <li>Designed for high-accuracy color workflows</li>
