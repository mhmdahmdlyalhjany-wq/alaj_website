<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="product_detail_template" name="Product Detail Page">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">

                    <style>
.alaj-pd-section { padding: 56px 0; }
@media (min-width: 768px) { .alaj-pd-section { padding: 80px 0; } }
.alaj-pd-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
}
@media (min-width: 992px) { .alaj-pd-grid { grid-template-columns: 1fr 1fr; gap: 48px; } }
.alaj-pd-gallery {
    background: #fff;
    border: 1px solid var(--alaj-border);
    border-radius: 8px;
    padding: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 400px;
}
.alaj-pd-gallery img {
    max-width: 100%;
    max-height: 360px;
    object-fit: contain;
}
.alaj-pd-brand {
    font-size: 11px;
    font-weight: 800;
    color: var(--alaj-red);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 8px;
}
.alaj-pd-name {
    font-family: var(--alaj-font-heading);
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--alaj-charcoal);
    margin: 0 0 12px;
    line-height: 1.2;
}
.alaj-pd-stock {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    background: rgba(34,197,94,0.08);
    color: #16a34a;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 20px;
}
.alaj-pd-stock svg { width: 14px; height: 14px; }
.alaj-pd-specs {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 24px;
}
.alaj-pd-specs tr { border-bottom: 1px solid var(--alaj-border); }
.alaj-pd-specs td {
    padding: 10px 0;
    font-size: 13px;
}
.alaj-pd-specs td:first-child {
    color: var(--alaj-stone);
    font-weight: 600;
    width: 40%;
}
.alaj-pd-specs td:last-child {
    color: var(--alaj-charcoal);
    font-weight: 700;
}
.alaj-pd-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    flex-wrap: wrap;
}
.alaj-qty-control {
    display: flex;
    align-items: center;
    border: 1px solid var(--alaj-border);
    border-radius: 6px;
    overflow: hidden;
}
.alaj-qty-btn {
    width: 38px;
    height: 38px;
    background: #fff;
    border: none;
    cursor: pointer;
    font-size: 16px;
    color: var(--alaj-charcoal);
    display: flex;
    align-items: center;
    justify-content: center;
}
.alaj-qty-btn:hover { background: var(--alaj-bg); }
.alaj-qty-value {
    width: 42px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: 700;
    border-left: 1px solid var(--alaj-border);
    border-right: 1px solid var(--alaj-border);
}
.alaj-fav-btn {
    width: 38px;
    height: 38px;
    border-radius: 6px;
    background: var(--alaj-bg);
    border: 1px solid var(--alaj-border);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
}
.alaj-fav-btn:hover { border-color: var(--alaj-red); }
.alaj-fav-btn svg { width: 16px; height: 16px; color: var(--alaj-stone); }

.alaj-reviews-section {
    margin-top: 40px;
    padding-top: 40px;
    border-top: 1px solid var(--alaj-border);
}
.alaj-review-card {
    background: #fff;
    border: 1px solid var(--alaj-border);
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 12px;
}
.alaj-review-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 8px;
}
.alaj-review-author {
    font-size: 13px;
    font-weight: 700;
    color: var(--alaj-charcoal);
    margin: 0;
}
.alaj-review-date {
    font-size: 11px;
    color: var(--alaj-stone);
    margin: 0;
}
.alaj-review-stars {
    color: #f59e0b;
    font-size: 14px;
    margin-bottom: 6px;
}
.alaj-review-text {
    font-size: 13px;
    color: var(--alaj-stone);
    line-height: 1.6;
    margin: 0;
}

.alaj-store-card-img { display: flex; align-items: center; justify-content: center; padding: 16px 0; margin-bottom: 16px; }
.alaj-store-card-img img { width: 100px; height: 100px; object-fit: contain; }
.alaj-store-arrow { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 700; color: var(--alaj-red); text-transform: uppercase; letter-spacing: 0.04em; }
.alaj-store-arrow svg { width: 14px; height: 14px; }
                    </style>

                    <section class="alaj-page-banner oe_img_bg" style="background-image: url('/alaj_website/static/src/binary/heroes/hero-home-default.jpg');" data-name="Page Hero">
                        <div class="alaj-banner-overlay">
                            <div class="container">
                                <h1>Product Details</h1>
                                <div class="alaj-breadcrumb">
                                    <a href="/">Home</a>
                                    <span>/</span>
                                    <a href="/products">Store</a>
                                    <span>/</span>
                                    <span class="active">Product Detail</span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt-5 pb-5" data-name="Product Detail">
                        <div class="container">
                            <div class="row">
                                <div class="col-lg-6 s_col_no_bgcolor pb16">
                                    <div class="alaj-pd-gallery" data-name="Product Gallery">
                                        <img src="/alaj_website/static/src/binary/products/dr-6000.png" alt="DR 6000"/>
                                    </div>
                                </div>
                                <div class="col-lg-6 s_col_no_bgcolor pb16" data-name="Product Info">
                                    <p class="alaj-pd-brand">HACH</p>
                                    <h1 class="alaj-pd-name">DR 6000 Without RFID Hach Lange</h1>
                                    <div class="alaj-pd-stock">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                        In-Stock
                                    </div>
                                    <p class="alaj-copy" style="margin-bottom:24px;">The DR 6000 is a high-performance UV-VIS spectrophotometer designed for laboratory water analysis. It features advanced spectrophotometry capabilities with a digital touch screen interface, USB connectivity, and pre-programmed methods for fast and accurate results.</p>

                                    <span class="alaj-kicker">Specifications</span>
                                    <table class="alaj-pd-specs">
                                        <tr><td>Display</td><td>Digital Touch Screen</td></tr>
                                        <tr><td>Interface</td><td>USB, Ethernet</td></tr>
                                        <tr><td>Wavelength Range</td><td>190 - 1100 nm</td></tr>
                                        <tr><td>Bandwidth</td><td>2 nm</td></tr>
                                        <tr><td>Photometric Range</td><td>-3 to 3 Abs</td></tr>
                                    </table>

                                    <div class="alaj-pd-actions">
                                        <div class="alaj-qty-control">
                                            <button class="alaj-qty-btn">-</button>
                                            <div class="alaj-qty-value">1</div>
                                            <button class="alaj-qty-btn">+</button>
                                        </div>
                                        <a href="/shop" class="btn-red">Add to Cart</a>
                                        <button class="alaj-fav-btn">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <div class="alaj-reviews-section">
                                <span class="alaj-kicker">Feedback</span>
                                <h2 class="alaj-heading">All Reviews</h2>
                                <p class="alaj-copy" style="margin-bottom:20px;">Based on 18 reviews</p>

                                <div class="alaj-review-card" data-name="Review">
                                    <div class="alaj-review-header">
                                        <p class="alaj-review-author">Ahmed K.</p>
                                        <p class="alaj-review-date">Jul 08, 2025</p>
                                    </div>
                                    <div class="alaj-review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                                    <p class="alaj-review-text">Excellent spectrophotometer. Very accurate readings and easy to use interface. Highly recommended for laboratory work.</p>
                                </div>
                                <div class="alaj-review-card" data-name="Review">
                                    <div class="alaj-review-header">
                                        <p class="alaj-review-author">Sarah M.</p>
                                        <p class="alaj-review-date">Jul 13, 2025</p>
                                    </div>
                                    <div class="alaj-review-stars">&#9733;&#9733;&#9733;&#9733;&#9734;</div>
                                    <p class="alaj-review-text">Great product overall. The touch screen is responsive and the pre-programmed methods save a lot of time.</p>
                                </div>
                                <div class="alaj-review-card" data-name="Review">
                                    <div class="alaj-review-header">
                                        <p class="alaj-review-author">Mohammed R.</p>
                                        <p class="alaj-review-date">Jul 21, 2025</p>
                                    </div>
                                    <div class="alaj-review-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                                    <p class="alaj-review-text">Best in class for water analysis. The UV-VIS capability makes it versatile for multiple applications.</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt-5 pb-5" style="background:#fff;" data-name="Related Products">
                        <div class="container">
                            <span class="alaj-kicker">Discover More</span>
                            <h2 class="alaj-heading" style="margin-bottom:24px;">Customers Also Viewed</h2>
                            <div class="row">
                                <div class="col-lg-3 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-store-card" data-name="Product Card">
                                        <div class="card-body">
                                            <div class="alaj-store-card-img"><img src="/alaj_website/static/src/binary/products/balance-scale.png" alt="Balance Scale"/></div>
                                            <h3 class="card-title" style="flex:1;">Balance Compact Scale 2000G X 1GM</h3>
                                            <a href="/shop" class="alaj-store-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-store-card" data-name="Product Card">
                                        <div class="card-body">
                                            <div class="alaj-store-card-img"><img src="/alaj_website/static/src/binary/products/hq1110-meter.png" alt="HQ1110"/></div>
                                            <h3 class="card-title" style="flex:1;">HQ1110 Portable pH/ORP Meter</h3>
                                            <a href="/shop" class="alaj-store-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-store-card" data-name="Product Card">
                                        <div class="card-body">
                                            <div class="alaj-store-card-img"><img src="/alaj_website/static/src/binary/products/lico-690.png" alt="LICO 690"/></div>
                                            <h3 class="card-title" style="flex:1;">LICO 690 Professional Spectral Colorimeter</h3>
                                            <a href="/shop" class="alaj-store-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-store-card" data-name="Product Card">
                                        <div class="card-body">
                                            <div class="alaj-store-card-img"><img src="/alaj_website/static/src/binary/products/dr-6000.png" alt="HPLC"/></div>
                                            <h3 class="card-title" style="flex:1;">HPLC Analytical Instrument</h3>
                                            <a href="/shop" class="alaj-store-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </template>

        <record id="product_detail_page" model="website.page">
            <field name="name">Product Detail</field>
            <field name="url">/product-detail</field>
            <field name="is_published">True</field>
            <field name="view_id" ref="product_detail_template"/>
            <field name="website_id" ref="alaj_website_record"/>
        </record>

        <record id="product_detail_template" model="ir.ui.view">
            <field name="website_id" ref="alaj_website_record"/>
        </record>

    </data>
</odoo>
