<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="about_page_template" name="About Us Page">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">

                    <style>
                        #wrap * { box-sizing: border-box; }
                        #wrap {
                            font-family: 'Poppins', 'Helvetica Neue', sans-serif;
                            color: #262138; line-height: 1.6;
                        }
                        .page-banner { position: relative; width: 100%; height: 400px; overflow: hidden; background-size: cover; background-position: center; background-repeat: no-repeat; }
                        .page-banner .banner-overlay {
                            position: absolute; inset: 0;
                            background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 100%);
                            display: flex; flex-direction: column; justify-content: center; padding: 0 56px;
                            pointer-events: none;
                        }
                        .page-banner .banner-overlay * { pointer-events: auto; }
                        .page-banner .banner-title {
                            color: #fff; font-family: 'Poppins', sans-serif;
                            font-size: 56px; font-weight: 700; margin: 0 0 16px;
                        }
                        .page-banner .breadcrumb {
                            display: flex; align-items: center; gap: 8px;
                            color: rgba(255,255,255,0.7); font-family: 'Poppins', sans-serif; font-size: 14px;
                        }
                        .page-banner .breadcrumb a { color: rgba(255,255,255,0.7); text-decoration: none; }
                        .page-banner .breadcrumb a:hover { color: #fff; }
                        .page-banner .breadcrumb .sep { margin: 0 4px; }
                        .page-banner .breadcrumb .current { color: #E1261C; }

                        .about-content { width: 100%; padding: 64px 56px; background: #EFF9FF; }
                        .about-inner { max-width: 1792px; margin: 0 auto; }

                        .about-intro {
                            display: grid; grid-template-columns: 1fr 1fr;
                            gap: 64px; align-items: center; margin-bottom: 80px;
                        }
                        .about-intro-title {
                            color: #262138; font-family: 'Poppins', sans-serif;
                            font-size: 36px; font-weight: 600; margin: 0 0 24px; line-height: 1.3;
                        }
                        .about-intro-text {
                            color: #4A4363; font-family: 'Poppins', sans-serif;
                            font-size: 16px; font-weight: 400; line-height: 1.8; margin: 0 0 16px;
                        }
                        .about-intro-img { border-radius: 20px; overflow: hidden; }
                        .about-intro-img img { width: 100%; height: auto; display: block; border-radius: 20px; }

                        .vm-section { margin-bottom: 80px; }
                        .vm-section-title {
                            color: #E1261C; font-family: 'Poppins', sans-serif;
                            font-size: 16px; font-weight: 600; text-transform: uppercase;
                            letter-spacing: 0.05em; margin: 0 0 8px;
                        }
                        .vm-section-heading {
                            color: #262138; font-family: 'Poppins', sans-serif;
                            font-size: 32px; font-weight: 600; margin: 0 0 40px;
                        }
                        .vm-grid {
                            display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px;
                        }
                        .vm-card {
                            background: #fff; border-radius: 20px; padding: 40px;
                            box-shadow: 0 4px 15px rgba(0,0,0,0.08); transition: box-shadow 0.2s;
                        }
                        .vm-card:hover { box-shadow: 0 8px 30px rgba(0,0,0,0.15); }
                        .vm-card-icon {
                            width: 64px; height: 64px; border-radius: 16px;
                            background: rgba(225,38,28,0.08);
                            display: flex; align-items: center; justify-content: center;
                            margin-bottom: 24px;
                        }
                        .vm-card-icon svg { width: 32px; height: 32px; color: #E1261C; }
                        .vm-card-title {
                            color: #262138; font-family: 'Poppins', sans-serif;
                            font-size: 22px; font-weight: 600; margin: 0 0 16px;
                        }
                        .vm-card-text {
                            color: #4A4363; font-family: 'Poppins', sans-serif;
                            font-size: 15px; font-weight: 400; line-height: 1.7; margin: 0;
                        }

                        .about-stats {
                            display: grid; grid-template-columns: repeat(4, 1fr);
                            gap: 32px; margin-bottom: 80px;
                        }
                        .about-stat-card {
                            background: #fff; border-radius: 20px; padding: 40px;
                            text-align: center;
                            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
                        }
                        .about-stat-num {
                            color: #E1261C; font-family: 'Poppins', sans-serif;
                            font-size: 48px; font-weight: 700; margin: 0 0 8px;
                        }
                        .about-stat-label {
                            color: #4A4363; font-family: 'Poppins', sans-serif;
                            font-size: 16px; font-weight: 500; margin: 0;
                        }

                        .heritage-section { margin-bottom: 80px; }
                        .heritage-title {
                            color: #E1261C; font-family: 'Poppins', sans-serif;
                            font-size: 16px; font-weight: 600; text-transform: uppercase;
                            letter-spacing: 0.05em; margin: 0 0 8px;
                        }
                        .heritage-heading {
                            color: #262138; font-family: 'Poppins', sans-serif;
                            font-size: 32px; font-weight: 600; margin: 0 0 24px;
                        }
                        .heritage-text {
                            color: #4A4363; font-family: 'Poppins', sans-serif;
                            font-size: 16px; font-weight: 400; line-height: 1.8;
                            margin: 0 0 16px; max-width: 900px;
                        }

                        .team-section {}
                        .team-title {
                            color: #E1261C; font-family: 'Poppins', sans-serif;
                            font-size: 16px; font-weight: 600; text-transform: uppercase;
                            letter-spacing: 0.05em; margin: 0 0 8px;
                        }
                        .team-heading {
                            color: #262138; font-family: 'Poppins', sans-serif;
                            font-size: 32px; font-weight: 600; margin: 0 0 40px;
                        }
                        .team-grid {
                            display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px;
                        }
                        .team-card {
                            background: #fff; border-radius: 20px; overflow: hidden;
                            box-shadow: 0 4px 15px rgba(0,0,0,0.08); text-align: center;
                        }
                        .team-card-img { width: 100%; height: 280px; overflow: hidden; }
                        .team-card-img img { width: 100%; height: 100%; object-fit: cover; }
                        .team-card-body { padding: 24px; }
                        .team-card-name {
                            color: #262138; font-family: 'Poppins', sans-serif;
                            font-size: 18px; font-weight: 600; margin: 0 0 4px;
                        }
                        .team-card-role {
                            color: #4A4363; font-family: 'Poppins', sans-serif;
                            font-size: 14px; font-weight: 400; margin: 0;
                        }

                        @media (max-width: 1200px) {
                            .vm-grid { grid-template-columns: 1fr 1fr; }
                            .about-stats { grid-template-columns: repeat(2, 1fr); }
                            .team-grid { grid-template-columns: repeat(2, 1fr); }
                        }
                        @media (max-width: 768px) {
                            .about-intro { grid-template-columns: 1fr; gap: 32px; }
                            .vm-grid { grid-template-columns: 1fr; }
                            .about-stats { grid-template-columns: 1fr 1fr; }
                            .team-grid { grid-template-columns: 1fr; }
                            .page-banner .banner-title { font-size: 36px; }
                            .about-content { padding: 40px 16px; }
                        }
                        @media (max-width: 480px) {
                            .about-stats { grid-template-columns: 1fr; }
                        }
                    </style>

                    <section class="page-banner oe_img_bg" style="background-image: url('/alaj_website/static/src/binary/heroes/hero-main.jpg');">
                        <div class="banner-overlay">
                            <h1 class="banner-title">About Us</h1>
                            <div class="breadcrumb">
                                <a href="/">Home</a>
                                <span class="sep">&gt;</span>
                                <span class="current">About Us</span>
                            </div>
                        </div>
                    </section>

                    <section class="about-content">
                        <div class="about-inner">

                            <div class="about-intro">
                                <div>
                                    <h2 class="about-intro-title">Over more than 30 years as distributor or Agent for Equipment of laboratories</h2>
                                    <p class="about-intro-text">Alajlabchem has continuously accompanied its customers across multiple market segments in a wide range of industries service providers growing to customers who are engaged in industries like Petrochemicals, Oil and Gas industry, Pharmaceuticals, Food and Beverage industry, Drinking Water, Wastewater, Utilities, Research institutes, Academic and university, Government agencies.</p>
                                    <p class="about-intro-text">We are proud to be one of the leading distributors and agents for laboratory equipment and water analysis solutions in the Kingdom of Saudi Arabia.</p>
                                </div>
                                <div class="about-intro-img">
                                    <img src="/alaj_website/static/src/binary/heroes/hero-overlay.jpg" alt="About Alajlabchem"/>
                                </div>
                            </div>

                            <div class="vm-section">
                                <p class="vm-section-title">Who We Are</p>
                                <h2 class="vm-section-heading">Vision, Mission &amp; Values</h2>
                                <div class="vm-grid">
                                    <div class="vm-card">
                                        <div class="vm-card-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                                        </div>
                                        <h3 class="vm-card-title">Our Vision</h3>
                                        <p class="vm-card-text">To be the leading provider of laboratory equipment and chemical solutions in the Kingdom and the region, setting the standard for quality and innovation.</p>
                                    </div>
                                    <div class="vm-card">
                                        <div class="vm-card-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
                                        </div>
                                        <h3 class="vm-card-title">Our Mission</h3>
                                        <p class="vm-card-text">Deliver exceptional laboratory products and services that empower researchers and industries to achieve breakthrough results with reliability and excellence.</p>
                                    </div>
                                    <div class="vm-card">
                                        <div class="vm-card-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                        </div>
                                        <h3 class="vm-card-title">Our Values</h3>
                                        <p class="vm-card-text">Integrity, quality, customer focus, and innovation drive everything we do. We are committed to building long-lasting partnerships based on trust.</p>
                                    </div>
                                </div>
                            </div>

                            <div class="about-stats">
                                <div class="about-stat-card">
                                    <p class="about-stat-num">30+</p>
                                    <p class="about-stat-label">Years of Experience</p>
                                </div>
                                <div class="about-stat-card">
                                    <p class="about-stat-num">500+</p>
                                    <p class="about-stat-label">Products Available</p>
                                </div>
                                <div class="about-stat-card">
                                    <p class="about-stat-num">100+</p>
                                    <p class="about-stat-label">Satisfied Clients</p>
                                </div>
                                <div class="about-stat-card">
                                    <p class="about-stat-num">50+</p>
                                    <p class="about-stat-label">Global Partners</p>
                                </div>
                            </div>

                            <div class="heritage-section">
                                <p class="heritage-title">Our Story</p>
                                <h2 class="heritage-heading">Our Heritage</h2>
                                <p class="heritage-text">Founded in 1990, Abdullatif H. Abdullatif &amp; Sons Co. started as a small distribution company in Jeddah. Over three decades, we have grown into one of the most trusted names in laboratory equipment and chemical solutions in the Kingdom of Saudi Arabia.</p>
                                <p class="heritage-text">Our journey has been marked by continuous growth, strategic partnerships with world-class manufacturers, and an unwavering commitment to quality. Today, we serve customers across multiple sectors including petrochemicals, pharmaceuticals, food and beverage, water treatment, and academic research.</p>
                            </div>

                            <div class="team-section">
                                <p class="team-title">Our People</p>
                                <h2 class="team-heading">Organizational Structure</h2>
                                <div class="team-grid">
                                    <div class="team-card">
                                        <div class="team-card-img"><img src="/alaj_website/static/src/binary/projects/project-1.jpg" alt="Team Member"/></div>
                                        <div class="team-card-body">
                                            <p class="team-card-name">Executive Director</p>
                                            <p class="team-card-role">Leadership</p>
                                        </div>
                                    </div>
                                    <div class="team-card">
                                        <div class="team-card-img"><img src="/alaj_website/static/src/binary/projects/project-2.jpg" alt="Team Member"/></div>
                                        <div class="team-card-body">
                                            <p class="team-card-name">Sales Manager</p>
                                            <p class="team-card-role">Sales Department</p>
                                        </div>
                                    </div>
                                    <div class="team-card">
                                        <div class="team-card-img"><img src="/alaj_website/static/src/binary/projects/project-1.jpg" alt="Team Member"/></div>
                                        <div class="team-card-body">
                                            <p class="team-card-name">Technical Director</p>
                                            <p class="team-card-role">Technical Support</p>
                                        </div>
                                    </div>
                                    <div class="team-card">
                                        <div class="team-card-img"><img src="/alaj_website/static/src/binary/projects/project-2.jpg" alt="Team Member"/></div>
                                        <div class="team-card-body">
                                            <p class="team-card-name">Operations Manager</p>
                                            <p class="team-card-role">Operations</p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </section>

                </div>
            </t>
        </template>

        <record id="about_page" model="website.page">
            <field name="name">About Us</field>
            <field name="url">/about</field>
            <field name="is_published">True</field>
            <field name="view_id" ref="about_page_template"/>
            <field name="website_id" ref="alaj_website_record"/>
        </record>

        <record id="menu_about" model="website.menu">
            <field name="name">About</field>
            <field name="url">/about</field>
            <field name="parent_id" ref="alaj_top_menu"/>
            <field name="website_id" ref="alaj_website_record"/>
            <field name="sequence">15</field>
        </record>

        <record id="about_page_template" model="ir.ui.view">
            <field name="website_id" ref="alaj_website_record"/>
        </record>
    </data>
</odoo>
