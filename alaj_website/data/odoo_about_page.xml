<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="about_page_template" name="About Us Page">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">

                    <style>
.about-content { padding: 64px 0; }
@media (max-width: 767px) { .about-content { padding: 40px 0; } }
.about-intro-img img { width: 100%; height: 400px; object-fit: cover; border-radius: 8px; }
@media (max-width: 767px) { .about-intro-img img { height: 280px; } }
.alaj-vm-card .card-body { padding: 28px; }
.alaj-vm-card-icon { width: 48px; height: 48px; border-radius: 10px; background: rgba(225,38,28,0.08); display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }
.alaj-vm-card-icon svg { width: 24px; height: 24px; color: var(--alaj-red); }
.alaj-stat-card .card-body { padding: 24px; text-align: center; }
.alaj-stat-number { font-family: var(--alaj-font-heading); font-size: 32px; font-weight: 700; color: var(--alaj-red); margin: 0 0 4px; }
.alaj-stat-text { font-size: 13px; font-weight: 600; color: var(--alaj-stone); margin: 0; }
                    </style>

                    <section class="alaj-page-banner oe_img_bg" style="background-image: url('/alaj_website/static/src/binary/heroes/hero-home-default.jpg');" data-name="Page Hero">
                        <div class="alaj-banner-overlay">
                            <div class="container">
                                <h1>About Us</h1>
                                <div class="alaj-breadcrumb">
                                    <a href="/">Home</a>
                                    <span>/</span>
                                    <span class="active">About Us</span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="about-content" data-name="About Intro">
                        <div class="container">
                            <div class="row align-items-center mb-5">
                                <div class="col-lg-6 s_col_no_bgcolor pb16">
                                    <span class="alaj-kicker">Who We Are</span>
                                    <h2 class="alaj-heading">Over more than 30 years as distributor and agent for laboratory equipment</h2>
                                    <p class="alaj-copy" style="margin-bottom:12px;">Alajlabchem has continuously accompanied its customers across multiple market segments in a wide range of industries service providers growing to customers who are engaged in industries like Petrochemicals, Oil and Gas industry, Pharmaceuticals, Food and Beverage industry, Drinking Water, Wastewater, Utilities, Research institutes, Academic and university, Government agencies.</p>
                                    <p class="alaj-copy">We are proud to be one of the leading distributors and agents for laboratory equipment and water analysis solutions in the Kingdom of Saudi Arabia.</p>
                                </div>
                                <div class="col-lg-6 s_col_no_bgcolor pb16">
                                    <div class="about-intro-img">
                                        <img src="/alaj_website/static/src/binary/heroes/hero-overlay.jpg" alt="About Alajlabchem"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section data-name="Vision Mission Values">
                        <div class="container">
                            <div class="text-center mb-4">
                                <span class="alaj-kicker">Our Foundation</span>
                                <h2 class="alaj-heading">Vision, Mission <span class="alaj-heading-ampersand">&amp;</span> Values</h2>
                            </div>
                            <div class="row">
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-vm-card" data-name="Vision Card">
                                        <div class="card-body">
                                            <div class="alaj-vm-card-icon">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>
                                            </div>
                                            <h3 class="card-title">Our Vision</h3>
                                            <p class="card-text">To be the leading provider of laboratory equipment and chemical solutions in the Kingdom and the region, setting the standard for quality and innovation.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-vm-card" data-name="Mission Card">
                                        <div class="card-body">
                                            <div class="alaj-vm-card-icon">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>
                                            </div>
                                            <h3 class="card-title">Our Mission</h3>
                                            <p class="card-text">Deliver exceptional laboratory products and services that empower researchers and industries to achieve breakthrough results with reliability and excellence.</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-vm-card" data-name="Values Card">
                                        <div class="card-body">
                                            <div class="alaj-vm-card-icon">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                                            </div>
                                            <h3 class="card-title">Our Values</h3>
                                            <p class="card-text">Integrity, quality, customer focus, and innovation drive everything we do. We are committed to building long-lasting partnerships based on trust.</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt-5 pb-5" data-name="Statistics">
                        <div class="container">
                            <div class="row">
                                <div class="col-lg-3 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-stat-card" data-name="Stat Card">
                                        <div class="card-body">
                                            <p class="alaj-stat-number">30+</p>
                                            <p class="alaj-stat-text">Years of Experience</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-stat-card" data-name="Stat Card">
                                        <div class="card-body">
                                            <p class="alaj-stat-number">500+</p>
                                            <p class="alaj-stat-text">Store Items Available</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-stat-card" data-name="Stat Card">
                                        <div class="card-body">
                                            <p class="alaj-stat-number">100+</p>
                                            <p class="alaj-stat-text">Satisfied Clients</p>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-stat-card" data-name="Stat Card">
                                        <div class="card-body">
                                            <p class="alaj-stat-number">50+</p>
                                            <p class="alaj-stat-text">Global Partners</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt-3 pb-5" data-name="Heritage">
                        <div class="container">
                            <span class="alaj-kicker">Our Story</span>
                            <h2 class="alaj-heading">Our Heritage</h2>
                            <p class="alaj-copy" style="margin-bottom:12px;max-width:900px;">Founded in 1990, Abdullatif H. Abdullatif <span class="alaj-ampersand">&amp;</span> Sons Co. started as a small distribution company in Jeddah. Over three decades, we have grown into one of the most trusted names in laboratory equipment and chemical solutions in the Kingdom of Saudi Arabia.</p>
                            <p class="alaj-copy" style="max-width:900px;">Our journey has been marked by continuous growth, strategic partnerships with world-class manufacturers, and an unwavering commitment to quality. Today, we serve customers across multiple sectors including petrochemicals, pharmaceuticals, food and beverage, water treatment, and academic research.</p>
                        </div>
                    </section>

                </div>
            </t>
        </template>

        <record id="about_page" model="website.page">
            <field name="name">About Us</field>
            <field name="url">/about</field>
            <field name="is_published">True</field>
            <field name="view_id" ref="about_page_template"/>
            <field name="website_id" ref="alaj_website_record"/>
        </record>

        <record id="menu_about" model="website.menu">
            <field name="name">About</field>
            <field name="url">/about</field>
            <field name="parent_id" ref="alaj_top_menu"/>
            <field name="website_id" ref="alaj_website_record"/>
            <field name="sequence">15</field>
        </record>

        <record id="about_page_template" model="ir.ui.view">
            <field name="website_id" ref="alaj_website_record"/>
        </record>
    </data>
</odoo>
