<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="events_page_template" name="Events Page">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">

                    <style>
.alaj-events-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 32px;
}
.alaj-events-filter {
    padding: 6px 16px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
    border: 1px solid var(--alaj-border);
    color: var(--alaj-stone);
    background: transparent;
    cursor: pointer;
}
.alaj-events-filter:hover,
.alaj-events-filter.active {
    border-color: var(--alaj-red);
    color: var(--alaj-red);
    background: rgba(225,38,28,0.04);
}
.alaj-events-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-bottom: 40px;
}
@media (min-width: 768px) { .alaj-events-grid { grid-template-columns: repeat(3, 1fr); gap: 20px; } }
.alaj-event-card {
    overflow: hidden;
    border-radius: 8px;
    background: #fff;
    border: 1px solid var(--alaj-border);
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
}
.alaj-event-card:hover {
    border-color: rgba(225,38,28,0.3);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    text-decoration: none;
}
.alaj-event-card-img {
    overflow: hidden;
    height: 200px;
}
.alaj-event-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
}
.alaj-event-card:hover .alaj-event-card-img img { transform: scale(1.05); }
.alaj-event-card-body { padding: 20px; }
.alaj-event-card-date {
    font-size: 11px;
    font-weight: 700;
    color: var(--alaj-red);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 6px;
}
.alaj-event-card-badge {
    display: inline-block;
    padding: 3px 10px;
    background: rgba(225,38,28,0.08);
    color: var(--alaj-red);
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
    margin-bottom: 10px;
}
.alaj-event-card-title {
    font-family: var(--alaj-font-body);
    font-size: 15px;
    font-weight: 700;
    color: var(--alaj-charcoal);
    margin: 0 0 8px;
    line-height: 1.4;
}
.alaj-event-card-desc {
    font-size: 13px;
    color: var(--alaj-stone);
    line-height: 1.6;
    margin: 0 0 12px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.alaj-event-card-loc {
    font-size: 12px;
    color: var(--alaj-stone);
    display: flex;
    align-items: center;
    gap: 4px;
}
.alaj-event-card-loc svg { width: 13px; height: 13px; }
.alaj-event-card-arrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 700;
    color: var(--alaj-red);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-top: 12px;
}
.alaj-event-card-arrow svg { width: 14px; height: 14px; }
.alaj-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
}
.alaj-page-btn {
    width: 36px;
    height: 36px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    background: #fff;
    border: 1px solid var(--alaj-border);
    font-size: 13px;
    font-weight: 600;
    color: var(--alaj-charcoal);
    transition: all 0.2s;
}
.alaj-page-btn.active { background: var(--alaj-red); color: #fff; border-color: var(--alaj-red); }
.alaj-page-btn:hover:not(.active) { border-color: var(--alaj-red); color: var(--alaj-red); }
                    </style>

                    <section class="alaj-page-banner oe_img_bg" style="background-image: url('/alaj_website/static/src/binary/heroes/hero-home-default.jpg');" data-name="Page Hero">
                        <div class="alaj-banner-overlay">
                            <div class="container">
                                <h1>Media Center</h1>
                                <div class="alaj-breadcrumb">
                                    <a href="/">Home</a>
                                    <span>/</span>
                                    <span class="active">Media Center</span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt-5 pb-5" data-name="Events">
                        <div class="container">
                            <div style="margin-bottom:32px;">
                                <span class="alaj-kicker">Stay Updated</span>
                                <h2 class="alaj-heading">News <span class="alaj-heading-ampersand">&amp;</span> Events</h2>
                            </div>
                            <div class="alaj-events-filters">
                                <button class="alaj-events-filter active">All</button>
                                <button class="alaj-events-filter">News</button>
                                <button class="alaj-events-filter">Events</button>
                                <button class="alaj-events-filter">Exhibitions</button>
                                <button class="alaj-events-filter">Announcements</button>
                            </div>
                            <div class="row mb-4">
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/event-detail" class="card h-100 alaj-event-card" data-name="Event Card" style="text-decoration:none;">
                                        <div class="alaj-event-card-img"><img src="/alaj_website/static/src/binary/news/event-1.jpg" alt="Event"/></div>
                                        <div class="card-body alaj-event-card-body">
                                            <p class="alaj-event-card-date">12 Mar 2025</p>
                                            <span class="alaj-event-card-badge">Exhibition</span>
                                            <h3 class="alaj-event-card-title">Saudi International Lab Expo 2025</h3>
                                            <p class="alaj-event-card-desc">Join us at the largest laboratory equipment exhibition in the Kingdom.</p>
                                            <p class="alaj-event-card-loc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> Riyadh, KSA</p>
                                            <span class="alaj-event-card-arrow">Read More <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                        </div>
                                    </a>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/event-detail" class="card h-100 alaj-event-card" data-name="Event Card" style="text-decoration:none;">
                                        <div class="alaj-event-card-img"><img src="/alaj_website/static/src/binary/news/event-2.jpg" alt="Event"/></div>
                                        <div class="card-body alaj-event-card-body">
                                            <p class="alaj-event-card-date">25 Feb 2025</p>
                                            <span class="alaj-event-card-badge">News</span>
                                            <h3 class="alaj-event-card-title">Advanced Spectral Colorimeters Launch</h3>
                                            <p class="alaj-event-card-desc">Introducing our newest range of professional spectral colorimeters.</p>
                                            <p class="alaj-event-card-loc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> Jeddah, KSA</p>
                                            <span class="alaj-event-card-arrow">Read More <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                        </div>
                                    </a>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/event-detail" class="card h-100 alaj-event-card" data-name="Event Card" style="text-decoration:none;">
                                        <div class="alaj-event-card-img"><img src="/alaj_website/static/src/binary/news/event-3.jpg" alt="Event"/></div>
                                        <div class="card-body alaj-event-card-body">
                                            <p class="alaj-event-card-date">10 Jan 2025</p>
                                            <span class="alaj-event-card-badge">Event</span>
                                            <h3 class="alaj-event-card-title">Annual Quality Workshop for Lab Professionals</h3>
                                            <p class="alaj-event-card-desc">Contact us for registration details and booth information.</p>
                                            <p class="alaj-event-card-loc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> Dammam, KSA</p>
                                            <span class="alaj-event-card-arrow">Read More <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                        </div>
                                    </a>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/event-detail" class="card h-100 alaj-event-card" data-name="Event Card" style="text-decoration:none;">
                                        <div class="alaj-event-card-img"><img src="/alaj_website/static/src/binary/news/event-4.jpg" alt="Event"/></div>
                                        <div class="card-body alaj-event-card-body">
                                            <p class="alaj-event-card-date">05 Dec 2024</p>
                                            <span class="alaj-event-card-badge">Announcement</span>
                                            <h3 class="alaj-event-card-title">Company Celebrates 30 Years of Excellence</h3>
                                            <p class="alaj-event-card-desc">Celebrating three decades of serving the chemical industry.</p>
                                            <p class="alaj-event-card-loc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> Riyadh, KSA</p>
                                            <span class="alaj-event-card-arrow">Read More <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                        </div>
                                    </a>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/event-detail" class="card h-100 alaj-event-card" data-name="Event Card" style="text-decoration:none;">
                                        <div class="alaj-event-card-img"><img src="/alaj_website/static/src/binary/news/featured-article.jpg" alt="Event"/></div>
                                        <div class="card-body alaj-event-card-body">
                                            <p class="alaj-event-card-date">18 Nov 2024</p>
                                            <span class="alaj-event-card-badge">Exhibition</span>
                                            <h3 class="alaj-event-card-title">Chemical Industry Forum 2024</h3>
                                            <p class="alaj-event-card-desc">The premier event for chemical industry professionals in the region.</p>
                                            <p class="alaj-event-card-loc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> Jeddah, KSA</p>
                                            <span class="alaj-event-card-arrow">Read More <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                        </div>
                                    </a>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/event-detail" class="card h-100 alaj-event-card" data-name="Event Card" style="text-decoration:none;">
                                        <div class="alaj-event-card-img"><img src="/alaj_website/static/src/binary/projects/project-1.jpg" alt="Event"/></div>
                                        <div class="card-body alaj-event-card-body">
                                            <p class="alaj-event-card-date">02 Oct 2024</p>
                                            <span class="alaj-event-card-badge">News</span>
                                            <h3 class="alaj-event-card-title">New Partnership with Global Lab Equipment Provider</h3>
                                            <p class="alaj-event-card-desc">Expanding our capabilities with world-class partnerships.</p>
                                            <p class="alaj-event-card-loc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> Dammam, KSA</p>
                                            <span class="alaj-event-card-arrow">Read More <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                        </div>
                                    </a>
                                </div>
                            </div>
                            <div class="alaj-pagination">
                                <button class="alaj-page-btn">&lt;</button>
                                <button class="alaj-page-btn active">1</button>
                                <button class="alaj-page-btn">2</button>
                                <button class="alaj-page-btn">3</button>
                                <button class="alaj-page-btn">&gt;</button>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </template>

        <record id="events_page" model="website.page">
            <field name="name">Media Center</field>
            <field name="url">/events</field>
            <field name="is_published">True</field>
            <field name="view_id" ref="events_page_template"/>
            <field name="website_id" ref="alaj_website_record"/>
        </record>

        <record id="menu_events" model="website.menu">
            <field name="name">Media Center</field>
            <field name="url">/events</field>
            <field name="parent_id" ref="alaj_top_menu"/>
            <field name="website_id" ref="alaj_website_record"/>
            <field name="sequence">40</field>
        </record>

        <record id="events_page_template" model="ir.ui.view">
            <field name="website_id" ref="alaj_website_record"/>
        </record>

    </data>
</odoo>
