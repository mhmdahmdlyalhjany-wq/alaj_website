<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="projects_page_template" name="Projects Page">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">

                    <style>
.alaj-proj-section { padding: 56px 0; }
@media (min-width: 768px) { .alaj-proj-section { padding: 80px 0; } }
.alaj-proj-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 32px;
}
.alaj-proj-filter {
    padding: 6px 16px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    transition: all 0.2s;
    border: 1px solid var(--alaj-border);
    color: var(--alaj-stone);
    background: transparent;
    cursor: pointer;
}
.alaj-proj-filter:hover,
.alaj-proj-filter.active {
    border-color: var(--alaj-red);
    color: var(--alaj-red);
    background: rgba(225,38,28,0.04);
}
.alaj-proj-page-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-bottom: 40px;
}
@media (min-width: 768px) { .alaj-proj-page-grid { grid-template-columns: repeat(3, 1fr); gap: 20px; } }
.alaj-proj-page-card {
    overflow: hidden;
    border-radius: 8px;
    background: #fff;
    border: 1px solid var(--alaj-border);
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
}
.alaj-proj-page-card:hover {
    border-color: rgba(225,38,28,0.3);
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    text-decoration: none;
}
.alaj-proj-page-card-img {
    overflow: hidden;
    height: 220px;
}
.alaj-proj-page-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
}
.alaj-proj-page-card:hover .alaj-proj-page-card-img img { transform: scale(1.05); }
.alaj-proj-page-card-body { padding: 20px; }
.alaj-proj-page-card-badge {
    display: inline-block;
    padding: 3px 10px;
    background: rgba(225,38,28,0.08);
    color: var(--alaj-red);
    border-radius: 4px;
    font-size: 11px;
    font-weight: 700;
    margin-bottom: 10px;
}
.alaj-proj-page-card-title {
    font-family: var(--alaj-font-body);
    font-size: 15px;
    font-weight: 700;
    color: var(--alaj-charcoal);
    margin: 0 0 8px;
    line-height: 1.4;
}
.alaj-proj-page-card-desc {
    font-size: 13px;
    color: var(--alaj-stone);
    line-height: 1.6;
    margin: 0 0 12px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.alaj-proj-page-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.alaj-proj-page-card-loc {
    font-size: 12px;
    color: var(--alaj-stone);
    display: flex;
    align-items: center;
    gap: 4px;
}
.alaj-proj-page-card-loc svg { width: 13px; height: 13px; }
.alaj-proj-page-card-arrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 700;
    color: var(--alaj-red);
    text-transform: uppercase;
    letter-spacing: 0.04em;
}
.alaj-proj-page-card-arrow svg { width: 14px; height: 14px; }
                    </style>

                    <section class="alaj-page-banner oe_img_bg" style="background-image: url('/alaj_website/static/src/binary/heroes/hero-home-default.jpg');" data-name="Page Hero">
                        <div class="alaj-banner-overlay">
                            <div class="container">
                                <h1>Our Projects</h1>
                                <div class="alaj-breadcrumb">
                                    <a href="/">Home</a>
                                    <span>/</span>
                                    <span class="active">Projects</span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt-5 pb-5" data-name="Projects">
                        <div class="container">
                            <div style="text-align:center;margin-bottom:32px;max-width:700px;margin-left:auto;margin-right:auto;">
                                <span class="alaj-kicker">Our Portfolio</span>
                                <h2 class="alaj-heading">Projects</h2>
                                <p class="alaj-copy" style="margin:0 auto;">Explore our portfolio of completed and ongoing projects across the Kingdom. We take pride in delivering excellence in every project we undertake.</p>
                            </div>
                            <div class="alaj-proj-filters">
                                <button class="alaj-proj-filter active">All Projects</button>
                                <button class="alaj-proj-filter">Petrochemical</button>
                                <button class="alaj-proj-filter">Water Treatment</button>
                                <button class="alaj-proj-filter">Pharmaceutical</button>
                                <button class="alaj-proj-filter">Research</button>
                            </div>
                            <div class="row mb-4">
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/projects" class="card h-100 alaj-proj-page-card" data-name="Project Card" style="text-decoration:none;">
                                        <div class="alaj-proj-page-card-img"><img src="/alaj_website/static/src/binary/projects/project-1.jpg" alt="Project"/></div>
                                        <div class="card-body alaj-proj-page-card-body">
                                            <span class="alaj-proj-page-card-badge">Petrochemical</span>
                                            <h3 class="alaj-proj-page-card-title">SABIC Petrochemical Lab Setup</h3>
                                            <p class="alaj-proj-page-card-desc">Complete laboratory equipment installation and setup for SABIC's new research facility.</p>
                                            <div class="alaj-proj-page-card-footer">
                                                <span class="alaj-proj-page-card-loc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> Riyadh, KSA</span>
                                                <span class="alaj-proj-page-card-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/projects" class="card h-100 alaj-proj-page-card" data-name="Project Card" style="text-decoration:none;">
                                        <div class="alaj-proj-page-card-img"><img src="/alaj_website/static/src/binary/projects/project-2.jpg" alt="Project"/></div>
                                        <div class="card-body alaj-proj-page-card-body">
                                            <span class="alaj-proj-page-card-badge">Water Treatment</span>
                                            <h3 class="alaj-proj-page-card-title">National Water Company Lab</h3>
                                            <p class="alaj-proj-page-card-desc">Supplied and installed advanced water analysis equipment for the National Water Company.</p>
                                            <div class="alaj-proj-page-card-footer">
                                                <span class="alaj-proj-page-card-loc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> Jeddah, KSA</span>
                                                <span class="alaj-proj-page-card-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/projects" class="card h-100 alaj-proj-page-card" data-name="Project Card" style="text-decoration:none;">
                                        <div class="alaj-proj-page-card-img"><img src="/alaj_website/static/src/binary/projects/project-1.jpg" alt="Project"/></div>
                                        <div class="card-body alaj-proj-page-card-body">
                                            <span class="alaj-proj-page-card-badge">Pharmaceutical</span>
                                            <h3 class="alaj-proj-page-card-title">SPIMACO Quality Lab Upgrade</h3>
                                            <p class="alaj-proj-page-card-desc">Full upgrade of pharmaceutical quality control laboratory with latest instruments.</p>
                                            <div class="alaj-proj-page-card-footer">
                                                <span class="alaj-proj-page-card-loc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> Qassim, KSA</span>
                                                <span class="alaj-proj-page-card-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/projects" class="card h-100 alaj-proj-page-card" data-name="Project Card" style="text-decoration:none;">
                                        <div class="alaj-proj-page-card-img"><img src="/alaj_website/static/src/binary/projects/project-2.jpg" alt="Project"/></div>
                                        <div class="card-body alaj-proj-page-card-body">
                                            <span class="alaj-proj-page-card-badge">Research</span>
                                            <h3 class="alaj-proj-page-card-title">KAUST Research Center</h3>
                                            <p class="alaj-proj-page-card-desc">Providing ongoing laboratory supplies and equipment maintenance for a premier research institution.</p>
                                            <div class="alaj-proj-page-card-footer">
                                                <span class="alaj-proj-page-card-loc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> Thuwal, KSA</span>
                                                <span class="alaj-proj-page-card-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/projects" class="card h-100 alaj-proj-page-card" data-name="Project Card" style="text-decoration:none;">
                                        <div class="alaj-proj-page-card-img"><img src="/alaj_website/static/src/binary/projects/project-1.jpg" alt="Project"/></div>
                                        <div class="card-body alaj-proj-page-card-body">
                                            <span class="alaj-proj-page-card-badge">Water Treatment</span>
                                            <h3 class="alaj-proj-page-card-title">Desalination Plant Lab</h3>
                                            <p class="alaj-proj-page-card-desc">Full laboratory setup for a major desalination plant including online analyzer instruments.</p>
                                            <div class="alaj-proj-page-card-footer">
                                                <span class="alaj-proj-page-card-loc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> Dammam, KSA</span>
                                                <span class="alaj-proj-page-card-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                                <div class="col-lg-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <a href="/projects" class="card h-100 alaj-proj-page-card" data-name="Project Card" style="text-decoration:none;">
                                        <div class="alaj-proj-page-card-img"><img src="/alaj_website/static/src/binary/projects/project-2.jpg" alt="Project"/></div>
                                        <div class="card-body alaj-proj-page-card-body">
                                            <span class="alaj-proj-page-card-badge">Petrochemical</span>
                                            <h3 class="alaj-proj-page-card-title">ARAMCO Lab Expansion</h3>
                                            <p class="alaj-proj-page-card-desc">Major laboratory expansion project including procurement and installation of new generation instruments.</p>
                                            <div class="alaj-proj-page-card-footer">
                                                <span class="alaj-proj-page-card-loc"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg> Dhahran, KSA</span>
                                                <span class="alaj-proj-page-card-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></span>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            </div>
                            <div class="alaj-pagination">
                                <button class="alaj-page-btn">&lt;</button>
                                <button class="alaj-page-btn active">1</button>
                                <button class="alaj-page-btn">2</button>
                                <button class="alaj-page-btn">&gt;</button>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </template>

        <record id="projects_page" model="website.page">
            <field name="name">Projects</field>
            <field name="url">/projects</field>
            <field name="is_published">True</field>
            <field name="view_id" ref="projects_page_template"/>
            <field name="website_id" ref="alaj_website_record"/>
        </record>

        <delete model="website.menu" search="[('url', '=', '/projects'), ('website_id', '=', ref('alaj_website_record'))]"/>

        <record id="projects_page_template" model="ir.ui.view">
            <field name="website_id" ref="alaj_website_record"/>
        </record>
    </data>
</odoo>
