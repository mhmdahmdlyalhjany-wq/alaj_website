<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="projects_page_template" name="Projects Page">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">

                    <style>
                        #wrap * { box-sizing: border-box; }
                        #wrap {
                            font-family: 'Poppins', 'Helvetica Neue', sans-serif;
                            color: #262138; line-height: 1.6;
                        }
                        .page-banner { position: relative; width: 100%; height: 400px; overflow: hidden; background-size: cover; background-position: center; background-repeat: no-repeat; }
                        .page-banner .banner-overlay {
                            position: absolute; inset: 0;
                            background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 100%);
                            display: flex; flex-direction: column; justify-content: center; padding: 0 56px;
                            pointer-events: none;
                        }
                        .page-banner .banner-overlay * { pointer-events: auto; }
                        .page-banner .banner-title {
                            color: #fff; font-family: 'Poppins', sans-serif;
                            font-size: 56px; font-weight: 700; margin: 0 0 16px;
                        }
                        .page-banner .breadcrumb {
                            display: flex; align-items: center; gap: 8px;
                            color: rgba(255,255,255,0.7); font-family: 'Poppins', sans-serif; font-size: 14px;
                        }
                        .page-banner .breadcrumb a { color: rgba(255,255,255,0.7); text-decoration: none; }
                        .page-banner .breadcrumb a:hover { color: #fff; }
                        .page-banner .breadcrumb .sep { margin: 0 4px; }
                        .page-banner .breadcrumb .current { color: #E1261C; }

                        .proj-content { width: 100%; padding: 64px 56px; background: #EFF9FF; }
                        .proj-inner { max-width: 1792px; margin: 0 auto; }

                        .proj-intro {
                            color: #4A4363; font-family: 'Poppins', sans-serif;
                            font-size: 18px; font-weight: 400; line-height: 1.8;
                            max-width: 900px; margin: 0 auto 64px; text-align: center;
                        }

                        .proj-tabs {
                            display: flex; align-items: center; gap: 16px;
                            margin-bottom: 40px; flex-wrap: wrap;
                        }
                        .proj-tab-btn {
                            padding: 10px 24px; border-radius: 9999px;
                            font-family: 'Poppins', sans-serif; font-size: 16px; font-weight: 500;
                            background: none; cursor: pointer; transition: all 0.2s;
                        }
                        .proj-tab-btn.active { border: 1px solid #E1261C; color: #E1261C; }
                        .proj-tab-btn:not(.active) { border: 1px solid transparent; color: rgba(34,34,34,0.5); }

                        .proj-grid {
                            display: grid; grid-template-columns: repeat(3, 1fr);
                            gap: 32px; margin-bottom: 48px;
                        }
                        .proj-card {
                            background: #fff; border-radius: 20px; overflow: hidden;
                            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
                            transition: box-shadow 0.2s; cursor: pointer;
                        }
                        .proj-card:hover { box-shadow: 0 8px 30px rgba(0,0,0,0.15); }
                        .proj-card-img { width: 100%; height: 280px; overflow: hidden; }
                        .proj-card-img img {
                            width: 100%; height: 100%; object-fit: cover;
                            transition: transform 0.3s;
                        }
                        .proj-card:hover .proj-card-img img { transform: scale(1.05); }
                        .proj-card-body { padding: 24px; }
                        .proj-card-badge {
                            display: inline-block; padding: 4px 12px;
                            background: rgba(225,38,28,0.1); color: #E1261C;
                            border-radius: 9999px; font-family: 'Poppins', sans-serif;
                            font-size: 12px; font-weight: 500; margin-bottom: 12px;
                        }
                        .proj-card-title {
                            color: #262138; font-family: 'Poppins', sans-serif;
                            font-size: 22px; font-weight: 600; margin: 0 0 12px; line-height: 1.4;
                        }
                        .proj-card-desc {
                            color: #4A4363; font-family: 'Poppins', sans-serif;
                            font-size: 14px; font-weight: 400; line-height: 1.7; margin: 0 0 16px;
                            display: -webkit-box; -webkit-line-clamp: 3;
                            -webkit-box-orient: vertical; overflow: hidden;
                        }
                        .proj-card-footer {
                            display: flex; align-items: center; justify-content: space-between;
                        }
                        .proj-card-loc {
                            color: #4A4363; font-family: 'Poppins', sans-serif;
                            font-size: 13px; display: flex; align-items: center; gap: 6px;
                        }
                        .proj-card-loc svg { width: 14px; height: 14px; }
                        .proj-card-arrow {
                            width: 42px; height: 42px; border-radius: 50%;
                            border: 1px solid #262138; background: none;
                            display: inline-flex; align-items: center; justify-content: center;
                            cursor: pointer; transition: all 0.2s; color: #262138; text-decoration: none;
                        }
                        .proj-card-arrow:hover { background: #262138; color: #fff; }
                        .proj-card-arrow svg { width: 20px; height: 20px; }
                        .arrow-icon { stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; fill: none; }

                        .pagination-row {
                            display: flex; align-items: center; justify-content: center; gap: 8px;
                        }
                        .page-btn {
                            width: 40px; height: 40px; border-radius: 50%;
                            display: flex; align-items: center; justify-content: center;
                            cursor: pointer; background: #fff; border: 1px solid #e5e7eb;
                            font-family: 'Poppins', sans-serif; font-size: 14px; font-weight: 500;
                            color: #262138; transition: all 0.2s;
                        }
                        .page-btn.active { background: #E1261C; color: #fff; border-color: #E1261C; }
                        .page-btn:hover:not(.active) { border-color: #E1261C; color: #E1261C; }

                        @media (max-width: 1200px) { .proj-grid { grid-template-columns: repeat(2, 1fr); } }
                        @media (max-width: 768px) {
                            .proj-grid { grid-template-columns: 1fr; }
                            .page-banner .banner-title { font-size: 36px; }
                            .proj-content { padding: 40px 16px; }
                        }
                    </style>

                    <section class="page-banner oe_img_bg" style="background-image: url('/alaj_website/static/src/binary/projects/project-1.jpg');">
                        <div class="banner-overlay">
                            <h1 class="banner-title">Our Projects</h1>
                            <div class="breadcrumb">
                                <a href="/">Home</a>
                                <span class="sep">&gt;</span>
                                <span class="current">Projects</span>
                            </div>
                        </div>
                    </section>

                    <section class="proj-content">
                        <div class="proj-inner">

                            <p class="proj-intro">Explore our portfolio of completed and ongoing projects across the Kingdom. We take pride in delivering excellence in every project we undertake.</p>

                            <div class="proj-tabs">
                                <button class="proj-tab-btn active">All Projects</button>
                                <button class="proj-tab-btn">Petrochemical</button>
                                <button class="proj-tab-btn">Water Treatment</button>
                                <button class="proj-tab-btn">Pharmaceutical</button>
                                <button class="proj-tab-btn">Research</button>
                            </div>

                            <div class="proj-grid">
                                <div class="proj-card">
                                    <div class="proj-card-img"><img src="/alaj_website/static/src/binary/projects/project-1.jpg" alt="Project"/></div>
                                    <div class="proj-card-body">
                                        <span class="proj-card-badge">Petrochemical</span>
                                        <h3 class="proj-card-title">SABIC Petrochemical Lab Setup</h3>
                                        <p class="proj-card-desc">Complete laboratory equipment installation and setup for SABIC's new research facility including water analysis instruments and chemical reagents.</p>
                                        <div class="proj-card-footer">
                                            <span class="proj-card-loc">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                                Riyadh, KSA
                                            </span>
                                            <a href="/projects" class="proj-card-arrow"><svg viewBox="0 0 24 24" class="arrow-icon"><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="proj-card">
                                    <div class="proj-card-img"><img src="/alaj_website/static/src/binary/projects/project-2.jpg" alt="Project"/></div>
                                    <div class="proj-card-body">
                                        <span class="proj-card-badge">Water Treatment</span>
                                        <h3 class="proj-card-title">National Water Company Lab</h3>
                                        <p class="proj-card-desc">Supplied and installed advanced water analysis equipment for the National Water Company's quality control laboratory.</p>
                                        <div class="proj-card-footer">
                                            <span class="proj-card-loc">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                                Jeddah, KSA
                                            </span>
                                            <a href="/projects" class="proj-card-arrow"><svg viewBox="0 0 24 24" class="arrow-icon"><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="proj-card">
                                    <div class="proj-card-img"><img src="/alaj_website/static/src/binary/projects/project-1.jpg" alt="Project"/></div>
                                    <div class="proj-card-body">
                                        <span class="proj-card-badge">Pharmaceutical</span>
                                        <h3 class="proj-card-title">SPIMACO Quality Lab Upgrade</h3>
                                        <p class="proj-card-desc">Full upgrade of pharmaceutical quality control laboratory with latest spectrophotometers and analytical instruments.</p>
                                        <div class="proj-card-footer">
                                            <span class="proj-card-loc">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                                Qassim, KSA
                                            </span>
                                            <a href="/projects" class="proj-card-arrow"><svg viewBox="0 0 24 24" class="arrow-icon"><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="proj-card">
                                    <div class="proj-card-img"><img src="/alaj_website/static/src/binary/projects/project-2.jpg" alt="Project"/></div>
                                    <div class="proj-card-body">
                                        <span class="proj-card-badge">Research</span>
                                        <h3 class="proj-card-title">KAUST Research Center</h3>
                                        <p class="proj-card-desc">Providing ongoing laboratory supplies and equipment maintenance for one of the Kingdom's premier research institutions.</p>
                                        <div class="proj-card-footer">
                                            <span class="proj-card-loc">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                                Thuwal, KSA
                                            </span>
                                            <a href="/projects" class="proj-card-arrow"><svg viewBox="0 0 24 24" class="arrow-icon"><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="proj-card">
                                    <div class="proj-card-img"><img src="/alaj_website/static/src/binary/projects/project-1.jpg" alt="Project"/></div>
                                    <div class="proj-card-body">
                                        <span class="proj-card-badge">Water Treatment</span>
                                        <h3 class="proj-card-title">Desalination Plant Lab</h3>
                                        <p class="proj-card-desc">Full laboratory setup for a major desalination plant including online analyzer instruments and chemical testing equipment.</p>
                                        <div class="proj-card-footer">
                                            <span class="proj-card-loc">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                                Dammam, KSA
                                            </span>
                                            <a href="/projects" class="proj-card-arrow"><svg viewBox="0 0 24 24" class="arrow-icon"><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="proj-card">
                                    <div class="proj-card-img"><img src="/alaj_website/static/src/binary/projects/project-2.jpg" alt="Project"/></div>
                                    <div class="proj-card-body">
                                        <span class="proj-card-badge">Petrochemical</span>
                                        <h3 class="proj-card-title">ARAMCO Lab Expansion</h3>
                                        <p class="proj-card-desc">Major laboratory expansion project including procurement and installation of new generation analytical instruments.</p>
                                        <div class="proj-card-footer">
                                            <span class="proj-card-loc">
                                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                                Dhahran, KSA
                                            </span>
                                            <a href="/projects" class="proj-card-arrow"><svg viewBox="0 0 24 24" class="arrow-icon"><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="pagination-row">
                                <button class="page-btn">&lt;</button>
                                <button class="page-btn active">1</button>
                                <button class="page-btn">2</button>
                                <button class="page-btn">&gt;</button>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </template>

        <record id="projects_page" model="website.page">
            <field name="name">Projects</field>
            <field name="url">/projects</field>
            <field name="is_published">True</field>
            <field name="view_id" ref="projects_page_template"/>
            <field name="website_id" ref="alaj_website_record"/>
        </record>

        <record id="menu_projects" model="website.menu">
            <field name="name">Projects</field>
            <field name="url">/projects</field>
            <field name="parent_id" ref="alaj_top_menu"/>
            <field name="website_id" ref="alaj_website_record"/>
            <field name="sequence">50</field>
        </record>

        <record id="projects_page_template" model="ir.ui.view">
            <field name="website_id" ref="alaj_website_record"/>
        </record>
    </data>
</odoo>
