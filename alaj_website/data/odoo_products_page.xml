<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="products_page_template" name="Legacy Store Page">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">

                    <style>
.alaj-store-filter { padding: 6px 16px; border-radius: 6px; font-size: 13px; font-weight: 600; text-decoration: none; transition: all 0.2s; border: 1px solid var(--alaj-border); color: var(--alaj-stone); background: transparent; }
.alaj-store-filter:hover, .alaj-store-filter.active { border-color: var(--alaj-red); color: var(--alaj-red); background: rgba(225,38,28,0.04); text-decoration: none; }
.alaj-store-search { display: flex; align-items: center; gap: 8px; padding: 8px 16px; background: #fff; border: 1px solid var(--alaj-border); border-radius: 6px; transition: border-color 0.2s; }
.alaj-store-search:focus-within { border-color: var(--alaj-red); }
.alaj-store-search svg { width: 18px; height: 18px; color: var(--alaj-stone); flex-shrink: 0; }
.alaj-store-search input { background: transparent; border: none; outline: none; color: var(--alaj-charcoal); font-family: var(--alaj-font-body); font-size: 13px; width: 160px; }
.alaj-store-search button { background: none; border: none; padding: 0; cursor: pointer; display: flex; }
.alaj-store-card .card-body { padding: 20px; display: flex; flex-direction: column; height: 100%; }
.alaj-store-card-img { display: flex; align-items: center; justify-content: center; padding: 16px 0; margin-bottom: 16px; }
.alaj-store-card-img img { width: 100px; height: 100px; object-fit: contain; }
.alaj-store-arrow { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 700; color: var(--alaj-red); text-transform: uppercase; letter-spacing: 0.04em; transition: gap 0.2s; }
.alaj-store-arrow svg { width: 14px; height: 14px; }
.alaj-store-card:hover .alaj-store-arrow { gap: 10px; }
                    </style>

                    <section class="alaj-page-banner oe_img_bg" style="background-image: url('/alaj_website/static/src/binary/heroes/hero-home-default.jpg');" data-name="Page Hero">
                        <div class="alaj-banner-overlay">
                            <div class="container">
                                <h1>Our Store</h1>
                                <div class="alaj-breadcrumb">
                                    <a href="/">Home</a>
                                    <span>/</span>
                                    <span class="active">Store</span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="pt-5 pb-5" data-name="Store">
                        <div class="container">
                            <div class="d-flex flex-wrap align-items-end justify-content-between gap-3 mb-4">
                                <div>
                                    <span class="alaj-kicker">Browse</span>
                                    <h2 class="alaj-heading">
                                        <span>Products</span>
                                        <span class="alaj-heading-ampersand">&amp;</span>
                                        <span>Equipment</span>
                                    </h2>
                                </div>
                                <div class="d-flex flex-wrap align-items-center gap-2">
                                    <div class="d-flex flex-wrap gap-2">
                                        <a href="/shop" class="alaj-store-filter active">All</a>
                                        <a href="/shop" class="alaj-store-filter">Instruments</a>
                                        <a href="/shop" class="alaj-store-filter">Analyzers</a>
                                        <a href="/shop" class="alaj-store-filter">Micro Biology</a>
                                        <a href="/shop" class="alaj-store-filter">Filter Paper</a>
                                        <a href="/shop" class="alaj-store-filter">Plasticware</a>
                                        <a href="/shop" class="alaj-store-filter">Glassware</a>
                                    </div>
                                    <form action="/shop" method="get" class="alaj-store-search">
                                        <button type="submit"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg></button>
                                        <input type="text" name="search" placeholder="Search store..."/>
                                    </form>
                                    <a href="/shop" class="btn-red">Visit Shop</a>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-lg-3 col-md-4 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-store-card" data-name="Product Card">
                                        <div class="card-body">
                                            <div class="alaj-store-card-img"><img src="/alaj_website/static/src/binary/products/balance-scale.png" alt="Balance Scale"/></div>
                                            <h3 class="card-title" style="flex:1;">Balance Compact Scale 2000G X 1GM</h3>
                                            <a href="/shop" class="alaj-store-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-4 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-store-card" data-name="Product Card">
                                        <div class="card-body">
                                            <div class="alaj-store-card-img"><img src="/alaj_website/static/src/binary/products/dr-6000.png" alt="DR 6000"/></div>
                                            <h3 class="card-title" style="flex:1;">DR 6000 Without RFID Hach Lange</h3>
                                            <a href="/shop" class="alaj-store-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-4 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-store-card" data-name="Product Card">
                                        <div class="card-body">
                                            <div class="alaj-store-card-img"><img src="/alaj_website/static/src/binary/products/hq1110-meter.png" alt="HQ1110"/></div>
                                            <h3 class="card-title" style="flex:1;">HQ1110 Portable pH/ORP Meter</h3>
                                            <a href="/shop" class="alaj-store-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-4 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-store-card" data-name="Product Card">
                                        <div class="card-body">
                                            <div class="alaj-store-card-img"><img src="/alaj_website/static/src/binary/products/lico-690.png" alt="LICO 690"/></div>
                                            <h3 class="card-title" style="flex:1;">LICO 690 Professional Spectral Colorimeter</h3>
                                            <a href="/shop" class="alaj-store-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-4 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-store-card" data-name="Product Card">
                                        <div class="card-body">
                                            <div class="alaj-store-card-img"><img src="/alaj_website/static/src/binary/products/balance-scale.png" alt="HPLC"/></div>
                                            <h3 class="card-title" style="flex:1;">HPLC Analytical Instrument</h3>
                                            <a href="/shop" class="alaj-store-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-4 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-store-card" data-name="Product Card">
                                        <div class="card-body">
                                            <div class="alaj-store-card-img"><img src="/alaj_website/static/src/binary/products/dr-6000.png" alt="Filter Paper"/></div>
                                            <h3 class="card-title" style="flex:1;">Filter Paper Premium Grade</h3>
                                            <a href="/shop" class="alaj-store-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-4 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-store-card" data-name="Product Card">
                                        <div class="card-body">
                                            <div class="alaj-store-card-img"><img src="/alaj_website/static/src/binary/products/hq1110-meter.png" alt="Glassware"/></div>
                                            <h3 class="card-title" style="flex:1;">Laboratory Glassware Set</h3>
                                            <a href="/shop" class="alaj-store-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-3 col-md-4 col-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="card h-100 alaj-store-card" data-name="Product Card">
                                        <div class="card-body">
                                            <div class="alaj-store-card-img"><img src="/alaj_website/static/src/binary/products/lico-690.png" alt="HACH Portable"/></div>
                                            <h3 class="card-title" style="flex:1;">HACH Portable pH/ORP Meter</h3>
                                            <a href="/shop" class="alaj-store-arrow">View <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                </div>
            </t>
        </template>

        <record id="products_page" model="website.page">
            <field name="name">Legacy Store</field>
            <field name="url">/products-legacy</field>
            <field name="is_published">False</field>
            <field name="view_id" ref="products_page_template"/>
            <field name="website_id" ref="alaj_website_record"/>
        </record>

        <record id="menu_products" model="website.menu">
            <field name="name">Store</field>
            <field name="url">/shop</field>
            <field name="parent_id" ref="alaj_top_menu"/>
            <field name="website_id" ref="alaj_website_record"/>
            <field name="sequence">20</field>
        </record>

        <record id="products_page_template" model="ir.ui.view">
            <field name="website_id" ref="alaj_website_record"/>
        </record>

    </data>
</odoo>
