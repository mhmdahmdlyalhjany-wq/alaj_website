<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="products_page_template" name="Products Page">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty">

                    <style>
                        #wrap * { box-sizing: border-box; }
                        #wrap {
                            font-family: 'Poppins', 'Helvetica Neue', sans-serif;
                            color: #262138;
                            line-height: 1.6;
                        }

                        .page-banner {
                            position: relative;
                            width: 100%;
                            height: 400px;
                            overflow: hidden;
                            background-size: cover;
                            background-position: center;
                            background-repeat: no-repeat;
                        }
                        .page-banner .banner-overlay {
                            position: absolute; inset: 0;
                            background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 100%);
                            display: flex; flex-direction: column;
                            justify-content: center;
                            padding: 0 56px;
                            pointer-events: none;
                        }
                        .page-banner .banner-overlay * { pointer-events: auto; }
                        .page-banner .banner-title {
                            color: #fff;
                            font-family: 'Poppins', sans-serif;
                            font-size: 56px; font-weight: 700;
                            margin: 0 0 16px;
                        }
                        .page-banner .breadcrumb {
                            display: flex; align-items: center; gap: 8px;
                            color: rgba(255,255,255,0.7);
                            font-family: 'Poppins', sans-serif;
                            font-size: 14px;
                        }
                        .page-banner .breadcrumb a {
                            color: rgba(255,255,255,0.7);
                            text-decoration: none;
                            transition: color 0.2s;
                        }
                        .page-banner .breadcrumb a:hover { color: #fff; }
                        .page-banner .breadcrumb .sep { margin: 0 4px; }
                        .page-banner .breadcrumb .current { color: #E1261C; }

                        .products-content {
                            width: 100%; padding: 64px 56px;
                            background: #EFF9FF;
                        }
                        .products-inner { max-width: 1792px; margin: 0 auto; }

                        .filters-bar {
                            display: flex; align-items: center;
                            justify-content: space-between;
                            gap: 32px; margin-bottom: 40px;
                            flex-wrap: wrap;
                        }
                        .cat-filters {
                            display: flex; align-items: center;
                            gap: 16px; flex-wrap: wrap;
                        }
                        .cat-btn {
                            padding: 10px 24px; border-radius: 9999px;
                            font-family: 'Poppins', sans-serif;
                            font-size: 16px; font-weight: 500;
                            background: none; cursor: pointer;
                            transition: all 0.2s;
                            text-decoration: none;
                        }
                        .cat-btn.active {
                            border: 1px solid #E1261C; color: #E1261C;
                        }
                        .cat-btn:not(.active) {
                            border: 1px solid transparent;
                            color: rgba(34,34,34,0.5);
                        }
                        .cat-btn:not(.active):hover { color: #222; }
                        .search-row {
                            display: flex; align-items: center; gap: 16px;
                        }
                        .search-box {
                            display: flex; align-items: center; gap: 12px;
                            padding: 10px 20px; background: #fff;
                            border-radius: 9999px; border: 1px solid #e5e7eb;
                        }
                        .search-box svg { width: 20px; height: 20px; color: #262138; }
                        .search-box input {
                            background: transparent; border: none; outline: none;
                            color: #9ca3af; font-family: 'Poppins', sans-serif;
                            font-size: 16px; width: 200px;
                        }
                        .store-btn {
                            display: inline-flex; align-items: center; gap: 12px;
                            padding: 12px 32px; background: #E1261C;
                            color: #fff; border-radius: 9999px;
                            border: none; cursor: pointer;
                            font-family: 'Poppins', sans-serif;
                            font-size: 16px; font-weight: 500;
                            text-decoration: none;
                        }
                        .store-btn:hover { background: rgba(225,38,28,0.9); }

                        .prod-grid {
                            display: grid;
                            grid-template-columns: repeat(4, 1fr);
                            gap: 32px; margin-bottom: 48px;
                        }
                        .prod-card {
                            background: #fff; border-radius: 20px;
                            padding: 20px;
                            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
                            transition: box-shadow 0.2s;
                        }
                        .prod-card:hover { box-shadow: 0 8px 30px rgba(0,0,0,0.15); }
                        .prod-card-head {
                            display: flex; align-items: center;
                            justify-content: space-between; margin-bottom: 20px;
                        }
                        .prod-menu-btn {
                            padding: 10px; border: 1px solid #E1261C;
                            border-radius: 24px; background: none; cursor: pointer;
                        }
                        .prod-menu-btn svg { width: 24px; height: 24px; color: #E1261C; }
                        .prod-fav-btn {
                            padding: 8px; background: #F1F3F9;
                            border-radius: 50%; border: none; cursor: pointer;
                        }
                        .prod-fav-btn svg { width: 20px; height: 20px; color: #6b7280; }
                        .prod-card-img {
                            margin-bottom: 20px; display: flex; justify-content: center;
                        }
                        .prod-card-img img { width: 120px; height: 120px; object-fit: contain; }
                        .prod-card-title {
                            color: #262138; font-family: 'Poppins', sans-serif;
                            font-size: 16px; font-weight: 500;
                            margin: 0 0 20px; min-height: 72px;
                            display: -webkit-box; -webkit-line-clamp: 3;
                            -webkit-box-orient: vertical; overflow: hidden;
                        }
                        .prod-arrow {
                            width: 42px; height: 42px; border-radius: 50%;
                            border: 1px solid #262138; background: none;
                            display: inline-flex; align-items: center; justify-content: center;
                            cursor: pointer; transition: all 0.2s;
                            text-decoration: none; color: #262138;
                        }
                        .prod-arrow:hover { background: #262138; color: #fff; }
                        .prod-arrow svg { width: 20px; height: 20px; }
                        .arrow-icon { stroke: currentColor; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; fill: none; }


                        @media (max-width: 1200px) {
                            .prod-grid { grid-template-columns: repeat(3, 1fr); }
                        }
                        @media (max-width: 768px) {
                            .prod-grid { grid-template-columns: repeat(2, 1fr); }
                            .filters-bar { flex-direction: column; align-items: flex-start; }
                            .page-banner .banner-title { font-size: 36px; }
                            .products-content { padding: 40px 16px; }
                            .cat-filters { gap: 8px; }
                            .cat-btn { font-size: 13px; padding: 8px 14px; }
                            .search-row { width: 100%; }
                            .search-box { flex: 1; }
                            .search-box input { width: 100%; }
                            .page-banner .banner-overlay { padding: 0 24px; }
                        }
                        @media (max-width: 480px) {
                            .prod-grid { grid-template-columns: 1fr; }
                            .page-banner .banner-title { font-size: 28px; }
                        }
                    </style>

                    <section class="page-banner oe_img_bg" style="background-image: url('/alaj_website/static/src/binary/heroes/hero-main.jpg');">
                        <div class="banner-overlay">
                            <h1 class="banner-title">Our Products</h1>
                            <div class="breadcrumb">
                                <a href="/">Home</a>
                                <span class="sep">&gt;</span>
                                <span class="current">Products</span>
                            </div>
                        </div>
                    </section>

                    <section class="products-content">
                        <div class="products-inner">
                            <div class="filters-bar">
                                <div class="cat-filters">
                                    <a href="/shop" class="cat-btn active">All Products</a>
                                    <a href="/shop" class="cat-btn">Machanical Instrument</a>
                                    <a href="/shop" class="cat-btn">Online Analyzer</a>
                                    <a href="/shop" class="cat-btn">Micro Biology</a>
                                    <a href="/shop" class="cat-btn">Filter Paper</a>
                                    <a href="/shop" class="cat-btn">Plasticware</a>
                                    <a href="/shop" class="cat-btn">Glassware</a>
                                </div>
                                <div class="search-row">
                                    <form action="/shop" method="get" class="search-box">
                                        <button type="submit" style="background:none;border:none;padding:0;cursor:pointer;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></button>
                                        <input type="text" name="search" placeholder="Search products..."/>
                                    </form>
                                    <a href="/shop" class="store-btn">Our Store</a>
                                </div>
                            </div>

                            <div class="prod-grid">
                                <div class="prod-card">
                                    <div class="prod-card-head">
                                        <button class="prod-menu-btn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 2.25h16a.75.75 0 010 1.5H4a.75.75 0 010-1.5z"/></svg></button>
                                        <button class="prod-fav-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></button>
                                    </div>
                                    <div class="prod-card-img"><img src="/alaj_website/static/src/binary/products/balance-scale.png" alt="Balance Scale"/></div>
                                    <p class="prod-card-title">*discontinued* BALANCE COMPACT SCALE 2000G X 1GM</p>
                                    <a href="/shop" class="prod-arrow"><svg viewBox="0 0 24 24" class="arrow-icon"><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg></a>
                                </div>
                                <div class="prod-card">
                                    <div class="prod-card-head">
                                        <button class="prod-menu-btn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 2.25h16a.75.75 0 010 1.5H4a.75.75 0 010-1.5z"/></svg></button>
                                        <button class="prod-fav-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></button>
                                    </div>
                                    <div class="prod-card-img"><img src="/alaj_website/static/src/binary/products/dr-6000.png" alt="DR 6000"/></div>
                                    <p class="prod-card-title">DR 6000 Without RFID Hach Lange</p>
                                    <a href="/shop" class="prod-arrow"><svg viewBox="0 0 24 24" class="arrow-icon"><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg></a>
                                </div>
                                <div class="prod-card">
                                    <div class="prod-card-head">
                                        <button class="prod-menu-btn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 2.25h16a.75.75 0 010 1.5H4a.75.75 0 010-1.5z"/></svg></button>
                                        <button class="prod-fav-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></button>
                                    </div>
                                    <div class="prod-card-img"><img src="/alaj_website/static/src/binary/products/hq1110-meter.png" alt="HQ1110"/></div>
                                    <p class="prod-card-title">HQ1110 Portable pH/ORP Meter</p>
                                    <a href="/shop" class="prod-arrow"><svg viewBox="0 0 24 24" class="arrow-icon"><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg></a>
                                </div>
                                <div class="prod-card">
                                    <div class="prod-card-head">
                                        <button class="prod-menu-btn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 2.25h16a.75.75 0 010 1.5H4a.75.75 0 010-1.5z"/></svg></button>
                                        <button class="prod-fav-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></button>
                                    </div>
                                    <div class="prod-card-img"><img src="/alaj_website/static/src/binary/products/lico-690.png" alt="LICO 690"/></div>
                                    <p class="prod-card-title">LICO 690 Professional Spectral Colorimeter</p>
                                    <a href="/shop" class="prod-arrow"><svg viewBox="0 0 24 24" class="arrow-icon"><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg></a>
                                </div>
                                <div class="prod-card">
                                    <div class="prod-card-head">
                                        <button class="prod-menu-btn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 2.25h16a.75.75 0 010 1.5H4a.75.75 0 010-1.5z"/></svg></button>
                                        <button class="prod-fav-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></button>
                                    </div>
                                    <div class="prod-card-img"><img src="/alaj_website/static/src/binary/products/balance-scale.png" alt="HPLC"/></div>
                                    <p class="prod-card-title">HPLC Analytical Instrument</p>
                                    <a href="/shop" class="prod-arrow"><svg viewBox="0 0 24 24" class="arrow-icon"><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg></a>
                                </div>
                                <div class="prod-card">
                                    <div class="prod-card-head">
                                        <button class="prod-menu-btn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 2.25h16a.75.75 0 010 1.5H4a.75.75 0 010-1.5z"/></svg></button>
                                        <button class="prod-fav-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></button>
                                    </div>
                                    <div class="prod-card-img"><img src="/alaj_website/static/src/binary/products/dr-6000.png" alt="Filter Paper"/></div>
                                    <p class="prod-card-title">Filter Paper Premium Grade</p>
                                    <a href="/shop" class="prod-arrow"><svg viewBox="0 0 24 24" class="arrow-icon"><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg></a>
                                </div>
                                <div class="prod-card">
                                    <div class="prod-card-head">
                                        <button class="prod-menu-btn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 2.25h16a.75.75 0 010 1.5H4a.75.75 0 010-1.5z"/></svg></button>
                                        <button class="prod-fav-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></button>
                                    </div>
                                    <div class="prod-card-img"><img src="/alaj_website/static/src/binary/products/hq1110-meter.png" alt="Glassware"/></div>
                                    <p class="prod-card-title">Laboratory Glassware Set</p>
                                    <a href="/shop" class="prod-arrow"><svg viewBox="0 0 24 24" class="arrow-icon"><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg></a>
                                </div>
                                <div class="prod-card">
                                    <div class="prod-card-head">
                                        <button class="prod-menu-btn"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 2.25h16a.75.75 0 010 1.5H4a.75.75 0 010-1.5z"/></svg></button>
                                        <button class="prod-fav-btn"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg></button>
                                    </div>
                                    <div class="prod-card-img"><img src="/alaj_website/static/src/binary/products/lico-690.png" alt="HACH Portable"/></div>
                                    <p class="prod-card-title">HACH Portable ph/ORP Meter</p>
                                    <a href="/shop" class="prod-arrow"><svg viewBox="0 0 24 24" class="arrow-icon"><path d="M7 7h10v10"/><path d="M7 17L17 7"/></svg></a>
                                </div>
                            </div>

                        </div>
                    </section>

                </div>
            </t>
        </template>

        <record id="products_page" model="website.page">
            <field name="name">Products</field>
            <field name="url">/products</field>
            <field name="is_published">True</field>
            <field name="view_id" ref="products_page_template"/>
            <field name="website_id" ref="alaj_website_record"/>
        </record>

        <record id="menu_products" model="website.menu">
            <field name="name">Products</field>
            <field name="url">/products</field>
            <field name="parent_id" ref="alaj_top_menu"/>
            <field name="website_id" ref="alaj_website_record"/>
            <field name="sequence">20</field>
        </record>

        <record id="products_page_template" model="ir.ui.view">
            <field name="website_id" ref="alaj_website_record"/>
        </record>

    </data>
</odoo>
