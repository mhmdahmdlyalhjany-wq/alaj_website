        <delete model="website.page" search="[('url', '=', '/'), ('website_id', '=', ref('holding_website_record')), ('view_id.key', '!=', 'holding_website.holding_homepage_template')]"/>

        <record id="holding_homepage_page" model="website.page">
            <field name="name">Home</field>
            <field name="url">/</field>
            <field name="is_published">True</field>
            <field name="website_id" ref="holding_website_record"/>
            <field name="view_id" ref="holding_homepage_template"/>
        </record>

        <record id="holding_menu_home" model="website.menu">
            <field name="name">Home</field>
            <field name="url">/</field>
            <field name="parent_id" ref="holding_top_menu"/>
            <field name="website_id" ref="holding_website_record"/>
            <field name="sequence">10</field>
        </record>

        <record id="holding_menu_about" model="website.menu">
            <field name="name">About Us</field>
            <field name="url">/about-us</field>
            <field name="parent_id" ref="holding_top_menu"/>
            <field name="website_id" ref="holding_website_record"/>
            <field name="sequence">20</field>
        </record>

        <record id="holding_menu_companies" model="website.menu">
            <field name="name">Our Companies</field>
            <field name="url">/our-companies</field>
            <field name="parent_id" ref="holding_top_menu"/>
            <field name="website_id" ref="holding_website_record"/>
            <field name="sequence">30</field>
        </record>

        <record id="holding_menu_media" model="website.menu">
            <field name="name">Media</field>
            <field name="url">/media-center</field>
            <field name="parent_id" ref="holding_top_menu"/>
            <field name="website_id" ref="holding_website_record"/>
            <field name="sequence">40</field>
        </record>

        <record id="holding_homepage_template" model="ir.ui.view">
            <field name="website_id" ref="holding_website_record"/>
        </record>
    </data>
</odoo>
