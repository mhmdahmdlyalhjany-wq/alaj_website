                                            <img src="/holding_website/static/src/img/acad2c41f22cfc2e663a7dd479822d6e32a76b4c.png" alt="Partner 2" class="holding-partner-logo"/>
                                            <img src="/holding_website/static/src/img/ed3d43a4cd4e9a4a9071f19697ced0d5ffaec25f.png" alt="Partner 3" class="holding-partner-logo"/>
                                            <img src="/holding_website/static/src/img/d7be44fb13329e3e8139e11ab4af2309b151bd97.png" alt="Partner 4" class="holding-partner-logo"/>
                                            <img src="/holding_website/static/src/img/5fd04aa806701207c978f542857d7e89e0bf748f.png" alt="Partner 5" class="holding-partner-logo"/>
                                            <img src="/holding_website/static/src/img/c8b5d98c99e10f59e2f7db821fe04890ded7bd91.png" alt="Partner 6" class="holding-partner-logo"/>
                                            <img src="/holding_website/static/src/img/fd816c6502199c2760f1f0f5bd2c5cdc0f13b4bd.png" alt="Partner 7" class="holding-partner-logo"/>
                                            <img src="/holding_website/static/src/img/324c65de1d668aed41817144c918063339da788a.png" alt="Partner 8" class="holding-partner-logo"/>
                                            <img src="/holding_website/static/src/img/c7ab286b55015964df1ce6cecdc34d88d142a207.png" alt="Partner 9" class="holding-partner-logo"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <section class="holding-content-section" id="media-section">
                        <div class="holding-section-shell">
                            <div class="holding-media-header">
                                <div>
                                    <h2 class="holding-media-title">Media / News</h2>
                                    <p class="holding-media-subtitle">check Our latest updates</p>
                                </div>
                                <a href="/media-center" class="holding-gradient-button">View All</a>
                            </div>

                            <div class="holding-news-grid">
                                <article class="holding-news-card">
                                    <div class="holding-news-media"><img src="/holding_website/static/src/img/188572ad050b9c99a60813308f8109bad202c5fb.png" alt="News 1" class="holding-news-media-image"/></div>
                                    <div class="holding-news-body">
                                        <div>
                                            <p class="holding-news-date">12 March 2025</p>
                                            <p class="holding-news-text">Title Text Goes here Title Text Goes here</p>
                                        </div>
                                        <a href="/media-center" class="holding-outline-button" aria-label="Read more">
                                            <svg viewBox="0 0 24 24">
                                                <path d="M5 12h14M12 5l7 7-7 7"/>
                                            </svg>
                                        </a>
                                    </div>
                                </article>

                                <article class="holding-news-card">
                                    <div class="holding-news-media"><img src="/holding_website/static/src/img/e63f3ba0b275cf99aef499d15fe0e95c59538b4e.png" alt="News 2" class="holding-news-media-image"/></div>
                                    <div class="holding-news-body">
                                        <div>
