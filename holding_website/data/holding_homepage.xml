                        <div class="holding-section-shell">
                            <div class="holding-partner-card">
                                <div class="holding-partner-blob"></div>
                                <div class="holding-section-shell holding-partner-inner">
                                    <div style="position:relative;">
                                        <p class="holding-watermark holding-partner-watermark">Be Our Partner</p>
                                        <h2 class="holding-partner-title">Be our partner</h2>
                                        <p class="holding-partner-copy">ABULJADYEL SKY Holding is the parent holding company of Abdullatif H. Abuljadayel &amp; Sons, serving as a strategic platform for managing and developing a diverse portfolio of companies across investment, real estate,</p>
                                        <ul class="holding-feature-list">
                                            <li>
                                                <svg viewBox="0 0 24 24">
                                                    <path d="M20 6L9 17l-5-5"/>
                                                </svg>
                                                <span>Meet Our SEO</span>
                                            </li>
                                            <li>
                                                <svg viewBox="0 0 24 24">
                                                    <path d="M20 6L9 17l-5-5"/>
