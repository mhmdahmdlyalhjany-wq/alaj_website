<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <template id="holding_homepage_template" name="Holding Homepage">
            <t t-call="website.layout">
                <div id="wrap" class="oe_structure oe_empty holding-page" t-attf-dir="#{request.env.lang and request.env.lang.startswith('ar') and 'rtl' or 'ltr'}">
                    <section class="holding-hero oe_img_bg" style="background-image: url('/holding_website/static/src/img/78d832971b0107023ee69c634af2b0275e427398.png');">
                        <div class="holding-hero-visual"></div>
                        <div class="holding-hero-blob"></div>
                        <div class="holding-section-shell holding-hero-content">
                            <h1 class="holding-hero-title">ABULJADYEL SKY <span>Holding</span></h1>
                            <a href="/#history-section" class="holding-hero-card">
                                <span class="holding-card-thumb oe_img_bg" style="background-image: url('/holding_website/static/src/img/78d832971b0107023ee69c634af2b0275e427398.png');">
                                    <span class="holding-play-badge">
                                        <span>
                                            <svg viewBox="0 0 16 16">
                                                <path d="M5.5 3.5l7 4.5-7 4.5V3.5z"/>
                                            </svg>
                                        </span>
                                    </span>
                                </span>
                                <span class="holding-card-copy">
                                    <strong>Our history</strong>
                                    <span>Watch video</span>
                                </span>
                            </a>
                        </div>
                    </section>

                    <section class="holding-content-section" id="about-section">
                        <div class="holding-section-shell">
                            <h2 class="holding-section-title">About Us</h2>
                            <p class="holding-copy">ABULJADYEL SKY Holding is the parent holding company of Abdullatif H. Abuljadayel &amp; Sons, serving as a strategic platform for managing and developing a diverse portfolio of companies across investment, real estate, industry, and technology. Its subsidiaries include Secure Growth, SKY Details, Abdullatif H. Abuljadayel &amp; Sons Co., ALAJCHEM Factory, and Cloud System. The holding company focuses on sustainable growth, value creation, and providing strategic support to ensure each subsidiary remains a leader and innovator in its sector.</p>
                        </div>
                    </section>

                    <section class="holding-content-section holding-companies" id="companies-section" data-name="Our Companies">
                        <div class="holding-companies-blob"></div>
                        <div class="holding-section-shell">
                            <h2 class="holding-section-title">Our Companies</h2>
                            <div class="row d-flex align-items-stretch holding-company-row">
                                <div class="col-xl-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="holding-company-card card text-bg-white h-100 is-highlight">
                                        <div class="card-body holding-company-card-body">
                                            <div class="holding-company-logo">
                                                <img src="/holding_website/static/src/img/Abdullatif.png" alt="Abdullatif H. Abuljadayel &amp; Sons Co." class="holding-company-image"/>
                                            </div>
                                            <h3 class="holding-company-title card-title">Abdullatif H. Abuljadayel &amp; Sons Co.</h3>
                                            <p class="holding-company-desc card-text">Established in 1984 single-handed by Sheik Abdullatif H. Abuljadayel It was started by acquiring worldwide known brands, HACH-For Water Quality</p>
                                            <div class="holding-company-action-wrap">
                                                <a href="#" class="holding-company-link btn">Visit website</a>
                                            </div>
                                            <div class="holding-company-accent">&#160;</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-xl-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="holding-company-card card text-bg-white h-100">
                                        <div class="card-body holding-company-card-body">
                                            <div class="holding-company-logo">
                                                <img src="/holding_website/static/src/img/image3.png" alt="Sky Details" class="holding-company-image"/>
                                            </div>
                                            <h3 class="holding-company-title card-title">About Sky Details</h3>
                                            <p class="holding-company-desc card-text">SKY Details is a real estate company specializing in property management and providing comprehensive solutions for investors and clients.</p>
                                            <div class="holding-company-action-wrap">
                                                <a href="#" class="holding-company-link btn">Visit website</a>
                                            </div>
                                            <div class="holding-company-accent">&#160;</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-xl-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="holding-company-card card text-bg-white h-100 is-highlight">
                                        <div class="card-body holding-company-card-body">
                                            <div class="holding-company-logo">
                                                <img src="/holding_website/static/src/img/d0d2b2b629a995e0f6539b48701978eae93a7ee4.png" alt="Cloud Systems Tech" class="holding-company-image"/>
                                            </div>
                                            <h3 class="holding-company-title card-title">Cloud Systems Tech</h3>
                                            <p class="holding-company-desc card-text">Cloud Systems for IT is a Saudi company under Abuljadayel Sky Holding, featuring a team of professional engineers, consultants, and experts in IT, digital transformation,</p>
                                            <div class="holding-company-action-wrap">
                                                <a href="#" class="holding-company-link btn">Visit website</a>
                                            </div>
                                            <div class="holding-company-accent">&#160;</div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row d-flex align-items-stretch holding-company-row holding-company-row-secondary">
                                <div class="col-xl-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="holding-company-card card text-bg-white h-100 is-highlight">
                                        <div class="card-body holding-company-card-body">
                                            <div class="holding-company-logo">
                                                <img src="/holding_website/static/src/img/d32546a2c1f63b13c15d94e35cc97f0321afd97c.png" alt="Secure Growth" class="holding-company-image"/>
                                            </div>
                                            <h3 class="holding-company-title card-title">Secure Growth</h3>
                                            <p class="holding-company-desc card-text">Cloud Systems for IT is a Saudi company under Abuljadayel Sky Holding, featuring a team of professional engineers, consultants, and experts in IT, digital transformation, ERP systems, and software development.</p>
                                            <div class="holding-company-action-wrap">
                                                <a href="#" class="holding-company-link btn">Visit website</a>
                                            </div>
                                            <div class="holding-company-accent">&#160;</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-xl-4 col-md-6 s_col_no_bgcolor pt16 pb16">
                                    <div class="holding-company-card card text-bg-white h-100">
                                        <div class="card-body holding-company-card-body">
                                            <div class="holding-company-logo">
                                                <img src="/holding_website/static/src/img/b502299d4187931475eea934395209906bfd8008.png" alt="ALAJCHEM Factory" class="holding-company-image"/>
                                            </div>
                                            <h3 class="holding-company-title card-title">ALAJCHEM Factory</h3>
                                            <p class="holding-company-desc card-text">Cloud Systems for IT is a Saudi company under Abuljadayel Sky Holding, featuring a team of professional engineers, consultants, and experts in IT, digital transformation, ERP systems, and software development.</p>
                                            <div class="holding-company-action-wrap">
                                                <a href="#" class="holding-company-link btn">Visit website</a>
                                            </div>
                                            <div class="holding-company-accent">&#160;</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

