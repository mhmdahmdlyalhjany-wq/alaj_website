<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="holding_website_record" model="website">
            <field name="name">holding website</field>
            <field name="default_lang_id" ref="base.lang_en"/>
            <field name="auto_redirect_lang">False</field>
            <field name="language_ids" eval="[(4, ref('base.lang_en')), (4, ref('base.lang_ar'))]"/>
        </record>

        <record id="holding_top_menu" model="website.menu">
            <field name="name">Holding Menu</field>
            <field name="website_id" ref="holding_website_record"/>
        </record>

        <record id="holding_website_record" model="website">
            <field name="menu_id" ref="holding_top_menu"/>
        </record>
    </data>
</odoo>
